---
import Navigation from '../components/Navigation.astro';

interface Props {
	title: string;
	showNavigation?: boolean;
}

const { title, showNavigation = true } = Astro.props;

// Get current user from middleware context
const user = Astro.locals.user;
const shouldShowNav = showNavigation && !!(user && (user as any).profile && (user as any).profile.status === 'approved');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="KSA CRM" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-950 text-gray-300 antialiased overflow-x-hidden">
		{shouldShowNav ? (
			<div class="flex min-h-screen">
				<Navigation />
				<main id="mainContent" class="flex-1 transition-all duration-300 ease-in-out p-4 pt-16 md:p-8">
					<slot />
				</main>
			</div>
		) : (
			<main class="min-h-screen">
				<slot />
			</main>
		)}
	</body>
</html>

<script>
  const mainContent = document.getElementById('mainContent');
  const nav = document.getElementById('mainNav');

  // Watch for changes in the nav element
  if (nav && mainContent) {
    // Create a mutation observer to detect class changes on the nav element
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          // Update main content when nav classes change
          const isCollapsed = nav.classList.contains('collapsed');
          if (isCollapsed) {
            mainContent.classList.add('collapsed');
          } else {
            mainContent.classList.remove('collapsed');
          }
        }
      });
    });

    // Start observing the navigation element
    observer.observe(nav, { attributes: true });

    // Initialize state from localStorage
    const savedState = localStorage.getItem('menuCollapsed');
    if (savedState === 'true' && window.innerWidth >= 768) {
      mainContent.classList.add('collapsed');
    } else {
      mainContent.classList.remove('collapsed');
    }
  }

  // Handle window resize
  function handleResize() {
    if (!mainContent) return;

    if (window.innerWidth <= 767) {
      // On mobile, main content takes full width
      mainContent.classList.remove('collapsed');
    } else {
      // On desktop, restore state from localStorage
      const savedState = localStorage.getItem('menuCollapsed');
      if (savedState === 'true') {
        mainContent.classList.add('collapsed');
      } else {
        mainContent.classList.remove('collapsed');
      }
    }
  }

  // Listen for window resize events
  window.addEventListener('resize', handleResize);

  // Initial check
  handleResize();
</script>

<style is:global>
	:root {
		--accent: 139, 92, 246; /* violet-500 */
		--accent-light: 196, 181, 253;
		--accent-dark: 76, 29, 149;
	}
	html {
		background: #020617; /* gray-950 */
		scroll-behavior: smooth;
	}

	/* Refined dark scrollbars */
	* {
		scrollbar-width: thin;
		scrollbar-color: #334155 transparent;
	}
	*::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	*::-webkit-scrollbar-thumb {
		background: #334155;
		border-radius: 8px;
	}
	*::-webkit-scrollbar-thumb:hover {
		background: #475569;
	}
	*::-webkit-scrollbar-track {
		background: transparent;
	}

	/* Consistent focus treatment for keyboard users */
	:focus-visible {
		outline: 2px solid rgb(var(--accent));
		outline-offset: 2px;
	}

	::selection {
		background: rgba(var(--accent), 0.35);
		color: #fff;
	}

	/* Native date/select controls render dark */
	input, select, textarea {
		color-scheme: dark;
	}
</style>

<style>
  /* Ensure smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }

  /* Main content positioning */
  #mainContent {
    margin-left: 16rem;
    width: calc(100% - 16rem);
    transition: margin 0.3s ease, width 0.3s ease;
  }

  #mainContent.collapsed {
    margin-left: 3rem;
    width: calc(100% - 3rem);
  }

  /* Responsive adjustments */
  @media (max-width: 767px) {
    #mainContent {
      margin-left: 0 !important;
      width: 100% !important;
    }
  }
</style>
