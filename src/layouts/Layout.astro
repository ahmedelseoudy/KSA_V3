---
import Navigation from '../components/Navigation.astro';

interface Props {
	title: string;
	showNavigation?: boolean;
}

const { title, showNavigation = true } = Astro.props;

// Get current user from middleware context
const user = Astro.locals.user;
const shouldShowNav = showNavigation && !!(user && (user as any).profile && (user as any).profile.status === 'approved');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="CRM System" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-900 overflow-x-hidden">
		{shouldShowNav ? (
			<div class="flex min-h-screen">
				<Navigation />
				<main id="mainContent" class="flex-1 transition-all duration-300 ease-in-out p-4">
					<slot />
				</main>
			</div>
		) : (
			<main class="min-h-screen">
				<slot />
			</main>
		)}
	</body>
</html>

<script>
  const mainContent = document.getElementById('mainContent');
  const nav = document.getElementById('mainNav');

  // Watch for changes in the nav element
  if (nav && mainContent) {
    // Create a mutation observer to detect class changes on the nav element
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          // Update main content when nav classes change
          const isCollapsed = nav.classList.contains('collapsed');
          if (isCollapsed) {
            mainContent.classList.add('collapsed');
          } else {
            mainContent.classList.remove('collapsed');
          }
        }
      });
    });

    // Start observing the navigation element
    observer.observe(nav, { attributes: true });

    // Initialize state from localStorage
    const savedState = localStorage.getItem('menuCollapsed');
    if (savedState === 'true' && window.innerWidth >= 768) {
      mainContent.classList.add('collapsed');
    } else {
      mainContent.classList.remove('collapsed');
    }
  }

  // Handle window resize
  function handleResize() {
    if (!mainContent) return;
    
    if (window.innerWidth <= 767) {
      // On mobile, main content takes full width
      mainContent.classList.remove('collapsed');
    } else {
      // On desktop, restore state from localStorage
      const savedState = localStorage.getItem('menuCollapsed');
      if (savedState === 'true') {
        mainContent.classList.add('collapsed');
      } else {
        mainContent.classList.remove('collapsed');
      }
    }
  }

  // Listen for window resize events
  window.addEventListener('resize', handleResize);
  
  // Initial check
  handleResize();
</script>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: system-ui, sans-serif;
		background: #13151A;
	}
</style>

<style>
  /* Ensure smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }

  /* Main content positioning */
  #mainContent {
    margin-left: 16rem;
    width: calc(100% - 16rem);
    transition: margin 0.3s ease, width 0.3s ease;
  }

  #mainContent.collapsed {
    margin-left: 1.5rem;
    width: calc(100% - 1.5rem);
  }

  /* Responsive adjustments */
  @media (max-width: 767px) {
    #mainContent {
      margin-left: 0 !important;
      width: 100% !important;
    }
  }
</style>