---
import ThemeInit from '../components/ThemeInit.astro';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="KSA CRM Authentication" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<ThemeInit />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-950 text-gray-300 antialiased min-h-screen auth-bg">
		<slot />
	</body>
</html>

<style is:global>
	/* Soft brand glow behind the auth card; alpha is dialed down in light mode
	   (see --auth-glow-alpha* in src/styles/global.css) so it doesn't overpower
	   a white background. */
	.auth-bg {
		background-image:
			radial-gradient(50rem 30rem at 50% -10%, rgba(139, 92, 246, var(--auth-glow-alpha)), transparent),
			radial-gradient(40rem 25rem at 85% 110%, rgba(59, 130, 246, var(--auth-glow-alpha-2)), transparent);
	}
</style>
