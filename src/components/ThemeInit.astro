---
// Sets the `dark`/`light` class on <html> before first paint, so there is no
// flash of the wrong theme. Must run as a plain synchronous inline script
// (not a module) and must be placed before any stylesheet link in <head>.
---

<script is:inline>
  (function () {
    var stored = localStorage.getItem('theme');
    var theme =
      stored === 'light' || stored === 'dark'
        ? stored
        : window.matchMedia('(prefers-color-scheme: light)').matches
          ? 'light'
          : 'dark';
    document.documentElement.classList.add(theme);
  })();
</script>
