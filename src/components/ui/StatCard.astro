---
interface Props {
  label: string;
  valueId?: string;
  valueClass?: string;
  value?: string | number;
}

const { label, valueId, valueClass = 'text-white', value } = Astro.props as Props;
---

<div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
  <p class="text-gray-400 text-sm">{label}</p>
  {valueId ? (
    <p id={valueId} class={`text-2xl font-bold ${valueClass}`}>{value ?? '-'}</p>
  ) : (
    <p class={`text-2xl font-bold ${valueClass}`}>{value ?? '-'}</p>
  )}
</div>
