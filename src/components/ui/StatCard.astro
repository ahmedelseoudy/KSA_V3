---
interface Props {
  label: string;
  valueId?: string;
  valueClass?: string;
  value?: string | number;
}

const { label, valueId, valueClass = 'text-white', value } = Astro.props as Props;
---

<div class="card p-5">
  <p class="text-gray-400 text-xs font-medium uppercase tracking-wider">{label}</p>
  {valueId ? (
    <p id={valueId} class={`text-3xl font-bold mt-2 tabular-nums ${valueClass}`}>{value ?? '-'}</p>
  ) : (
    <p class={`text-3xl font-bold mt-2 tabular-nums ${valueClass}`}>{value ?? '-'}</p>
  )}
</div>
