---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props as Props;
---

<header class="mb-8">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="min-w-0">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-white">{title}</h1>
      {subtitle && <p class="text-sm text-gray-400 mt-1.5">{subtitle}</p>}
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <slot name="actions" />
    </div>
  </div>
</header>
