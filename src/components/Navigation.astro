---
import { NAV_ITEMS } from '../utils/navigation/constants';

// Get current user from middleware context
const user = Astro.locals.user;
const userRole = (user as any)?.profile?.role || 'user';
const userEmail = (user as any)?.email || '';
const roleLabel = userRole.replace(/_/g, ' ');

// Filter navigation items based on user role, preserving group order
const allowedNavItems = NAV_ITEMS.filter(item => item.roles.includes(userRole));
const groups: { name: string; items: typeof allowedNavItems }[] = [];
for (const item of allowedNavItems) {
  const existing = groups.find(g => g.name === item.group);
  if (existing) existing.items.push(item);
  else groups.push({ name: item.group, items: [item] });
}

// Heroicons-style outline paths keyed by NavItem.icon
const ICON_PATHS: Record<string, string> = {
  'home': 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75',
  'cube': 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
  'building': 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  'clipboard': 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z',
  'check-circle': 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'document': 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  'truck': 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  'scale': 'M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z',
  'chart': 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
  'users': 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  'mail': 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
};
const LOGOUT_PATH = 'M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9';

const isActive = (path: string) => Astro.url.pathname === path;
---

<div class="navigation-wrapper">
  <nav id="mainNav" class="nav-menu bg-gray-900 border-r border-gray-800">
    <div class="nav-content flex flex-col">

      <!-- Brand -->
      <div class="flex items-center gap-3 px-5 h-16 shrink-0 border-b border-gray-800">
        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-purple-600 text-white font-bold text-sm shadow-card">K</div>
        <div class="leading-tight">
          <p class="text-white font-semibold text-sm tracking-wide">KSA CRM</p>
          <p class="text-gray-500 text-[11px] capitalize">{roleLabel} workspace</p>
        </div>
      </div>

      <!-- Nav groups -->
      <div class="flex-1 overflow-y-auto px-3 py-4 space-y-6">
        {groups.map(group => (
          <div>
            {groups.length > 1 && (
              <p class="px-3 mb-1.5 text-[11px] font-semibold uppercase tracking-wider text-gray-500">{group.name}</p>
            )}
            <ul class="space-y-0.5">
              {group.items.map(item => (
                <li>
                  <a
                    href={item.path}
                    aria-current={isActive(item.path) ? 'page' : undefined}
                    class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors ${
                      isActive(item.path)
                        ? 'bg-purple-600/15 text-purple-300 font-medium ring-1 ring-inset ring-purple-500/30'
                        : 'text-gray-400 hover:bg-gray-800 hover:text-gray-100'
                    }`}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class={`w-5 h-5 shrink-0 ${isActive(item.path) ? 'text-purple-400' : 'text-gray-500'}`}>
                      <path stroke-linecap="round" stroke-linejoin="round" d={ICON_PATHS[item.icon] || ICON_PATHS['home']} />
                    </svg>
                    <span class="truncate">{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- User footer -->
      <div class="shrink-0 border-t border-gray-800 p-3">
        <div class="flex items-center gap-3 px-2 py-2">
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-800 text-gray-300 text-sm font-semibold uppercase shrink-0">
            {userEmail.charAt(0) || '?'}
          </div>
          <div class="min-w-0 flex-1 leading-tight">
            <p class="text-gray-200 text-xs font-medium truncate" title={userEmail}>{userEmail}</p>
            <p class="text-gray-500 text-[11px] capitalize">{roleLabel}</p>
          </div>
          <button
            id="nav-logout-btn"
            class="p-2 rounded-lg text-gray-500 hover:text-red-400 hover:bg-red-500/10 transition-colors shrink-0"
            title="Sign out"
            aria-label="Sign out"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d={LOGOUT_PATH} />
            </svg>
          </button>
        </div>
      </div>

    </div>
  </nav>

  <!-- Mobile toggle button (always visible on mobile) -->
  <button class="mobile-toggle-btn md:hidden fixed top-3 right-3 z-50 p-2 rounded-lg bg-gray-800 border border-gray-700 text-gray-300 hover:text-white hover:bg-gray-700 shadow-card" aria-label="Toggle menu">
    <svg xmlns="http://www.w3.org/2000/svg" class="toggle-icon h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <!-- Desktop toggle button (outside the collapsible area) -->
  <button
    id="desktopMenuToggle"
    class="desktop-toggle-btn hidden md:flex fixed z-[100] items-center justify-center w-6 h-6 rounded-full bg-gray-800 border border-gray-700 text-gray-400 hover:text-white hover:bg-gray-700 hover:border-gray-600 shadow-card transition-all"
    aria-label="Toggle menu (Ctrl+M)"
    title="Toggle menu (Ctrl+M)"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="toggle-icon h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
</div>

<style>
  /* Navigation wrapper */
  .navigation-wrapper {
    position: relative;
  }

  /* Base navigation styles */
  .nav-menu {
    position: fixed;
    left: 0;
    top: 0;
    width: 16rem; /* 256px */
    height: 100vh;
    transition: width 0.3s ease, transform 0.3s ease;
    z-index: 50;
  }

  .nav-content {
    width: 16rem;
    transition: opacity 0.3s ease, width 0.3s ease;
    height: 100vh;
  }

  /* Collapsed state */
  .nav-menu.collapsed {
    width: 0;
  }

  .nav-menu.collapsed .nav-content {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }

  /* Desktop toggle button: docked to the sidebar edge */
  .desktop-toggle-btn {
    left: calc(16rem - 0.75rem);
    top: 1.25rem;
    transition: left 0.3s ease, transform 0.3s ease, background 0.2s ease;
  }

  /* When menu is collapsed, move toggle button to screen edge */
  .nav-menu.collapsed ~ .desktop-toggle-btn {
    left: 0.75rem;
  }

  /* Icon animation */
  .toggle-icon {
    transform: rotate(0deg);
    transition: transform 0.3s;
  }

  .nav-menu.collapsed ~ .desktop-toggle-btn .toggle-icon {
    transform: rotate(180deg);
  }

  /* Responsive behavior */
  @media (max-width: 767px) {
    .nav-menu {
      transform: translateX(-100%);
      width: 85%;
      max-width: 16rem;
    }

    .nav-menu.open {
      transform: translateX(0);
      box-shadow: 0 0 24px rgba(0, 0, 0, 0.6);
    }
  }
</style>

<script>
  const nav = document.getElementById('mainNav');
  const mainContent = document.getElementById('mainContent');
  const mobileToggleBtn = document.querySelector('.mobile-toggle-btn');
  const desktopToggleBtn = document.getElementById('desktopMenuToggle');

  // Toggle menu function
  function toggleMenu() {
    const isMobile = window.innerWidth <= 767;

    nav.classList.toggle('collapsed');

    // For mobile screens
    if (isMobile) {
      nav.classList.toggle('open');
    }

    // For desktop screens
    if (!isMobile) {
      mainContent.classList.toggle('collapsed');
    }

    // Save state to localStorage
    saveState();
  }

  // Add event listeners to toggle buttons
  if (mobileToggleBtn) {
    mobileToggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      toggleMenu();
    });
  }

  if (desktopToggleBtn) {
    desktopToggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      toggleMenu();
    });
  }

  // Keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.key.toLowerCase() === 'm') {
      e.preventDefault();
      toggleMenu();
    }
  });

  // Create an overlay for mobile
  const overlay = document.createElement('div');
  overlay.classList.add('menu-overlay');
  document.body.appendChild(overlay);

  // When clicking overlay, close menu
  overlay.addEventListener('click', () => {
    nav.classList.remove('open');
    overlay.classList.remove('active');
  });

  // Handle mobile toggle specially
  if (mobileToggleBtn) {
    mobileToggleBtn.addEventListener('click', () => {
      overlay.classList.toggle('active');
    });
  }

  // Handle responsive state
  const mediaQuery = window.matchMedia('(max-width: 767px)');
  function handleMediaChange(e) {
    if (e.matches) {
      // Mobile view
      nav.classList.remove('collapsed');
      nav.classList.remove('open');
      mainContent.classList.remove('collapsed');
      overlay.classList.remove('active');
    } else {
      // Desktop view: apply saved state
      if (localStorage.getItem('menuCollapsed') === 'true') {
        nav.classList.add('collapsed');
        mainContent.classList.add('collapsed');
      } else {
        nav.classList.remove('collapsed');
        mainContent.classList.remove('collapsed');
      }
    }
  }

  // Listen for changes to media query
  mediaQuery.addEventListener('change', handleMediaChange);

  // Initial setup
  handleMediaChange(mediaQuery);

  // Save state to localStorage
  function saveState() {
    if (nav) {
      localStorage.setItem('menuCollapsed', nav.classList.contains('collapsed').toString());
    }
  }

  const navLogoutBtn = document.getElementById('nav-logout-btn');

  // Logout functionality
  if (navLogoutBtn) {
    navLogoutBtn.addEventListener('click', async () => {
      try {
        await fetch('/api/logout', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      } catch (error) {
        console.error('Error signing out:', error);
      } finally {
        window.location.href = '/login';
      }
    });
  }
</script>

<style is:global>
  /* Menu overlay for mobile (element is created in JS, so styles must be global) */
  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 40;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .menu-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .menu-overlay {
      display: none;
    }
  }
</style>
