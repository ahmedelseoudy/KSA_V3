---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Order Batches - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-white">Order Batches</h1>
      <button id="createBatchBtn" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
        + New Order Batch
      </button>
    </div>

    <!-- Filters -->
    <div class="bg-gray-800 rounded-lg p-4 mb-6">
      <div class="flex gap-4 items-end">
        <select id="statusFilter" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none">
          <option value="">All Status</option>
          <option value="draft">Draft</option>
          <option value="availability_sent">Availability Sent</option>
          <option value="po_sent">PO Sent</option>
          <option value="partially_delivered">Partially Delivered</option>
          <option value="completed">Completed</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>
    </div>

    <!-- Batches List -->
    <div id="batchesList" class="space-y-4">
      <div class="text-center text-gray-400 py-8">Loading order batches...</div>
    </div>

    <!-- Upload Orders Modal -->
    <div id="uploadModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
      <div class="bg-gray-800 rounded-xl p-6 w-full max-w-xl mx-4">
        <h2 class="text-xl font-bold text-white mb-2">Upload Orders</h2>
        <p class="text-sm text-gray-400 mb-4">XLSX/CSV with columns: barcode, order_qty, asin, title, total cost. Items will be matched against your products database by barcode.</p>
        <input type="hidden" id="uploadBatchId" />
        <div class="border-2 border-dashed border-gray-600 rounded-lg p-8 text-center mb-4">
          <input type="file" id="ordersFileInput" accept=".xlsx,.xls,.csv" class="hidden" />
          <p class="text-gray-400">Drop file here or <button type="button" class="text-purple-400 hover:text-purple-300" onclick="document.getElementById('ordersFileInput').click()">browse</button></p>
          <p id="selectedOrdersFile" class="text-gray-500 text-xs mt-2">No file selected</p>
        </div>
        <div id="ordersUploadProgress" class="hidden mb-4 text-sm text-gray-400">Processing…</div>
        <div id="ordersUploadResult" class="hidden mb-4 text-sm"></div>
        <div id="uploadActions" class="flex justify-end gap-3">
          <button type="button" id="closeUploadModal" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-500">Close</button>
          <button type="button" id="startOrdersUpload" disabled class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 disabled:opacity-50">Upload</button>
        </div>
      </div>
    </div>

    <!-- Batch Detail Modal -->
    <div id="batchDetailModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
      <div class="bg-gray-800 rounded-xl p-6 w-full max-w-5xl mx-4 max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold text-white" id="batchDetailTitle">Batch Items</h2>
          <button id="closeBatchDetail" class="text-gray-400 hover:text-white text-2xl leading-none">&times;</button>
        </div>
        <!-- Stats row -->
        <div class="grid grid-cols-4 gap-3 mb-4" id="batchDetailStats">
          <div class="bg-gray-700 rounded-lg p-3">
            <p class="text-xs text-gray-400">Total Items</p>
            <p class="text-xl font-bold text-white" id="detailTotal">-</p>
          </div>
          <div class="bg-green-900/30 rounded-lg p-3">
            <p class="text-xs text-gray-400">Matched</p>
            <p class="text-xl font-bold text-green-400" id="detailMatched">-</p>
          </div>
          <div class="bg-red-900/30 rounded-lg p-3">
            <p class="text-xs text-gray-400">Unmatched</p>
            <p class="text-xl font-bold text-red-400" id="detailMissing">-</p>
          </div>
          <div class="bg-purple-900/30 rounded-lg p-3">
            <p class="text-xs text-gray-400">Total Value</p>
            <p class="text-xl font-bold text-purple-400" id="detailValue">-</p>
          </div>
        </div>
        <!-- Tabs -->
        <div class="flex gap-2 mb-4">
          <button id="tabAll" onclick="window.switchTab('all')" class="px-3 py-1 text-sm rounded-full bg-purple-600 text-white">All</button>
          <button id="tabMatched" onclick="window.switchTab('matched')" class="px-3 py-1 text-sm rounded-full bg-gray-700 text-gray-300 hover:bg-gray-600">Matched</button>
          <button id="tabMissing" onclick="window.switchTab('missing')" class="px-3 py-1 text-sm rounded-full bg-gray-700 text-gray-300 hover:bg-gray-600">Unmatched</button>
        </div>
        <!-- Table -->
        <div class="overflow-auto flex-1">
          <table class="w-full text-sm">
            <thead class="bg-gray-700 sticky top-0">
              <tr>
                <th class="px-3 py-2 text-left text-gray-300">Barcode</th>
                <th class="px-3 py-2 text-left text-gray-300">Title</th>
                <th class="px-3 py-2 text-left text-gray-300">Company</th>
                <th class="px-3 py-2 text-right text-gray-300">Order Qty</th>
                <th class="px-3 py-2 text-right text-gray-300">Amazon Cost</th>
                <th class="px-3 py-2 text-right text-gray-300">Provider Cost</th>
                <th class="px-3 py-2 text-right text-gray-300">P&L</th>
                <th class="px-3 py-2 text-center text-gray-300">Status</th>
              </tr>
            </thead>
            <tbody id="batchDetailTableBody">
              <tr><td colspan="8" class="px-4 py-6 text-center text-gray-400">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Create Batch Modal -->
    <div id="createModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
      <div class="bg-gray-800 rounded-xl p-6 w-full max-w-lg mx-4">
        <h2 class="text-xl font-bold text-white mb-4">Create Order Batch</h2>
        <form id="createForm" class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Batch Name *</label>
            <input type="text" name="name" required placeholder="e.g. March 2025 Order"
              class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">PO Number</label>
            <input type="text" name="po_number" placeholder="e.g. PO-2025-001"
              class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Notes</label>
            <textarea name="notes" rows="3" placeholder="Optional notes..."
              class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none"></textarea>
          </div>
          <div class="flex justify-end gap-3 pt-2">
            <button type="button" id="closeCreateModal" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-500">Cancel</button>
            <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">Create Batch</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import * as XLSX from 'xlsx';

  const statusColors: Record<string, string> = {
    draft: 'bg-gray-700 text-gray-300',
    availability_sent: 'bg-blue-900/30 text-blue-300',
    po_sent: 'bg-purple-900/30 text-purple-300',
    partially_delivered: 'bg-yellow-900/30 text-yellow-300',
    completed: 'bg-green-900/30 text-green-300',
    cancelled: 'bg-red-900/30 text-red-300',
  };

  async function loadBatches() {
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';
    const params = new URLSearchParams();
    if (status) params.set('status', status);

    const resp = await fetch(`/api/orders?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderBatches(data || []);
  }

  function renderBatches(batches: any[]) {
    const container = document.getElementById('batchesList');
    if (!container) return;

    if (batches.length === 0) {
      container.innerHTML = '<div class="text-center text-gray-400 py-8">No order batches found. Create one to get started.</div>';
      return;
    }

    container.innerHTML = batches.map(b => `
      <div class="bg-gray-800 rounded-lg p-5 border border-gray-700 hover:border-gray-600 transition-colors">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-lg font-semibold text-white">${b.name}</h3>
            <p class="text-sm text-gray-400 mt-1">
              ${b.po_number ? `PO: ${b.po_number} · ` : ''}
              ${b.total_items} items · $${Number(b.total_value || 0).toFixed(2)}
            </p>
            ${b.notes ? `<p class="text-sm text-gray-500 mt-1">${b.notes}</p>` : ''}
            <p class="text-xs text-gray-500 mt-2">Created: ${new Date(b.created_at).toLocaleDateString()}</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 text-xs rounded-full ${statusColors[b.status] || 'bg-gray-700 text-gray-300'}">
              ${b.status.replace(/_/g, ' ')}
            </span>
            <button onclick="window.viewBatchItems('${b.id}', '${b.name.replace(/'/g, "\\'")}}')" class="text-sm text-purple-400 hover:text-purple-300">View Items →</button>
          </div>
        </div>
        <div class="flex gap-3 mt-4 pt-3 border-t border-gray-700">
          ${b.status === 'draft' ? `
            <button onclick="window.openUpload('${b.id}')" class="text-sm text-purple-400 hover:text-purple-300">Upload Orders</button>
            <button onclick="window.sendAvailability('${b.id}')" class="text-sm text-blue-400 hover:text-blue-300" ${b.total_items === 0 ? 'disabled title="Upload orders first"' : ''}>Send Availability Requests</button>
          ` : ''}
          ${b.status === 'availability_sent' ? `
            <button onclick="window.generatePOs('${b.id}')" class="text-sm text-purple-400 hover:text-purple-300">Generate Purchase Orders</button>
            <a href="/availability?batch_id=${b.id}" class="text-sm text-green-400 hover:text-green-300">View Responses</a>
          ` : ''}
          ${['po_sent', 'partially_delivered'].includes(b.status) ? `
            <a href="/deliveries?batch_id=${b.id}" class="text-sm text-yellow-400 hover:text-yellow-300">Track Deliveries</a>
          ` : ''}
          <button onclick="window.deleteBatch('${b.id}')" class="text-sm text-red-400 hover:text-red-300 ml-auto">Delete</button>
        </div>
      </div>
    `).join('');
  }

  // Create batch
  document.getElementById('createBatchBtn')?.addEventListener('click', () => {
    document.getElementById('createModal')?.classList.remove('hidden');
  });
  document.getElementById('closeCreateModal')?.addEventListener('click', () => {
    document.getElementById('createModal')?.classList.add('hidden');
  });

  document.getElementById('createForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    const resp = await fetch('/api/orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: formData.get('name'),
        po_number: formData.get('po_number') || null,
        notes: formData.get('notes') || null,
      }),
    });

    if (resp.ok) {
      document.getElementById('createModal')?.classList.add('hidden');
      form.reset();
      loadBatches();
    } else {
      const err = await resp.json();
      alert(err.error || 'Failed to create batch');
    }
  });

  // Actions
  (window as any).sendAvailability = async (batchId: string) => {
    if (!confirm('Send availability requests to all companies in this batch?')) return;
    const resp = await fetch('/api/availability', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'generate', batch_id: batchId }),
    });
    if (resp.ok) {
      const result = await resp.json();
      const failed = result.emails_failed?.length || 0;
      const failedDetail = failed ? `\n${failed} email(s) failed: ${result.emails_failed.map((f: any) => f.error).join('; ')}` : '';
      alert(`Sent availability requests to ${result.created} companies. ${result.emails_sent || 0} emails delivered.${failedDetail}`);
      loadBatches();
    } else {
      const err = await resp.json();
      alert(err.error || 'Failed to send availability requests');
    }
  };

  (window as any).generatePOs = async (batchId: string) => {
    const poNumber = prompt('Enter PO number for purchase orders:');
    if (!poNumber) return;
    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'generate', batch_id: batchId, po_number: poNumber }),
    });
    if (resp.ok) {
      const result = await resp.json();
      const failed = result.emails_failed?.length || 0;
      const failedDetail = failed ? `\n${failed} email(s) failed: ${result.emails_failed.map((f: any) => f.error).join('; ')}` : '';
      alert(`Created ${result.created} purchase orders. ${result.emails_sent || 0} emails delivered.${failedDetail}`);
      loadBatches();
    } else {
      const err = await resp.json();
      alert(err.error || 'Failed to generate purchase orders');
    }
  };

  (window as any).deleteBatch = async (id: string) => {
    if (!confirm('Delete this order batch and all its items?')) return;
    // Note: cascade delete handles items
    const resp = await fetch(`/api/orders?id=${id}`, { method: 'DELETE' });
    if (resp.ok) loadBatches();
    else alert('Failed to delete batch');
  };

  // Filter
  document.getElementById('statusFilter')?.addEventListener('change', loadBatches);

  // ===== Upload Orders modal =====
  let ordersFile: File | null = null;

  function pickCol(row: any, keys: string[]): any {
    for (const k of keys) {
      if (row[k] !== undefined && row[k] !== null && String(row[k]).trim() !== '') return row[k];
      const lower = k.toLowerCase();
      const found = Object.keys(row).find((rk) => rk.toLowerCase() === lower);
      if (found && row[found] !== undefined && row[found] !== null && String(row[found]).trim() !== '') return row[found];
    }
    return null;
  }

  function parseNumber(v: any): number {
    if (v === null || v === undefined || v === '') return 0;
    const cleaned = String(v).replace(/[$,\s]/g, '');
    const n = parseFloat(cleaned);
    return isNaN(n) ? 0 : n;
  }

  (window as any).openUpload = (batchId: string) => {
    (document.getElementById('uploadBatchId') as HTMLInputElement).value = batchId;
    ordersFile = null;
    document.getElementById('selectedOrdersFile')!.textContent = 'No file selected';
    document.getElementById('ordersUploadProgress')!.classList.add('hidden');
    document.getElementById('ordersUploadResult')!.classList.add('hidden');
    (document.getElementById('startOrdersUpload') as HTMLButtonElement).disabled = true;
    document.getElementById('uploadModal')?.classList.remove('hidden');
  };

  document.getElementById('closeUploadModal')?.addEventListener('click', () => {
    document.getElementById('uploadModal')?.classList.add('hidden');
  });

  document.getElementById('ordersFileInput')?.addEventListener('change', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.files?.[0]) {
      ordersFile = input.files[0];
      document.getElementById('selectedOrdersFile')!.textContent = ordersFile.name;
      (document.getElementById('startOrdersUpload') as HTMLButtonElement).disabled = false;
    }
  });

  document.getElementById('startOrdersUpload')?.addEventListener('click', async () => {
    if (!ordersFile) return;
    const batchId = (document.getElementById('uploadBatchId') as HTMLInputElement).value;
    const progress = document.getElementById('ordersUploadProgress')!;
    const result = document.getElementById('ordersUploadResult')!;
    progress.classList.remove('hidden');
    progress.textContent = 'Parsing file…';
    result.classList.add('hidden');

    try {
      const buffer = await ordersFile.arrayBuffer();
      const wb = XLSX.read(buffer, { type: 'array' });
      const sheet = wb.Sheets[wb.SheetNames[0]];
      const rows: any[] = XLSX.utils.sheet_to_json(sheet, { defval: '' });

      const items = rows.map((row) => {
        // Extract barcode - handle Excel scientific notation conversion
        const rawBarcode = pickCol(row, [
          'barcode', 'Barcode', 'BARCODE',
          'External ID', 'external id', 'external_id', 'EXTERNAL ID',
          'EAN', 'ean', 'Ean',
          'SKU', 'sku', 'Sku',
          'Product Code', 'product code', 'product_code'
        ]);
        
        if (!rawBarcode) return null;
        
        // Convert to string and handle scientific notation
        let barcode = '';
        if (typeof rawBarcode === 'number') {
          // Excel converted to number - format with full precision
          barcode = rawBarcode.toFixed(0);
        } else {
          barcode = String(rawBarcode);
        }
        
        // Normalize: remove spaces, commas, and trim
        barcode = barcode.replace(/[,\s]/g, '').trim();
        if (!barcode || barcode === '0') return null;
        
        const orderQty = parseNumber(pickCol(row, [
          'order_qty', 'Order_Qty', 'ORDER_QTY',
          'Quantity', 'quantity', 'QUANTITY', 'Qty', 'qty', 'QTY',
          'Quantity Requested', 'quantity requested', 'QUANTITY REQUESTED',
          'Order Quantity', 'order quantity', 'ORDER QUANTITY',
          'Ordered', 'ordered', 'ORDERED'
        ]));
        
        const asin = String(pickCol(row, [
          'asin', 'ASIN', 'Asin',
          'Item Code', 'item code', 'item_code', 'ITEM CODE',
          'itemcode', 'ItemCode', 'ITEMCODE'
        ]) || '');
        
        const title = String(pickCol(row, [
          'title', 'Title', 'TITLE',
          'ItemDescEn', 'itemdescen', 'ITEMDESCEN',
          'Item Description', 'item description', 'ITEM DESCRIPTION',
          'description', 'Description', 'DESCRIPTION',
          'Product Name', 'product name', 'PRODUCT NAME',
          'Name', 'name', 'NAME'
        ]) || '');
        
        const amazonCost = parseNumber(pickCol(row, [
          'total cost', 'Total Cost', 'TOTAL COST',
          'total_cost', 'Total_Cost', 'TOTAL_COST',
          'amazon_cost', 'Amazon Cost', 'AMAZON COST',
          'Amazon_Cost', 'AMAZON_COST',
          'cost', 'Cost', 'COST',
          'Price', 'price', 'PRICE',
          'Unit Price', 'unit price', 'UNIT PRICE',
          'Amount', 'amount', 'AMOUNT'
        ]));
        
        return { barcode, order_qty: orderQty, asin, title, amazon_cost: amazonCost };
      }).filter((it): it is NonNullable<typeof it> => it !== null);

      if (items.length === 0) {
        progress.classList.add('hidden');
        result.classList.remove('hidden');
        result.innerHTML = '<span class="text-red-400">No valid rows found. Check that the file has a barcode column.</span>';
        return;
      }
      
      // Debug: Log first item to see what was extracted
      console.log('Sample extracted item:', items[0]);
      console.log('Available columns in Excel:', Object.keys(rows[0] || {}));

      progress.textContent = `Uploading ${items.length} items…`;
      const resp = await fetch('/api/order-items', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ batch_id: batchId, items }),
      });
      const json = await resp.json();

      progress.classList.add('hidden');
      result.classList.remove('hidden');
      if (!resp.ok) {
        result.innerHTML = `<span class="text-red-400">Error: ${json.error || 'Upload failed'}</span>`;
        return;
      }
      result.innerHTML = `
        <div class="text-green-400 font-semibold">✓ Upload complete!</div>
        <div class="text-gray-300 mt-1">${json.saved} items saved — <span class="text-green-400">${json.matched} matched</span>, <span class="text-red-400">${json.missing} unmatched</span>.</div>
        ${json.errors?.length ? `<div class="text-red-400 text-xs mt-1">${json.errors.length} insert error(s)</div>` : ''}
        <div class="text-gray-500 text-xs mt-2">Closing in 3 seconds…</div>
      `;
      // Hide the upload button to prevent double-submit
      (document.getElementById('startOrdersUpload') as HTMLButtonElement).disabled = true;
      loadBatches();
      // Auto-close after 3 seconds
      setTimeout(() => {
        document.getElementById('uploadModal')?.classList.add('hidden');
        result.classList.add('hidden');
        progress.classList.add('hidden');
      }, 3000);
    } catch (err: any) {
      progress.classList.add('hidden');
      result.classList.remove('hidden');
      result.innerHTML = `<span class="text-red-400">${err?.message || 'Failed to parse file'}</span>`;
    }
  });

  // ===== Batch Detail Modal =====
  let allBatchItems: any[] = [];
  let activeTab = 'all';

  (window as any).viewBatchItems = async (batchId: string, batchName: string) => {
    document.getElementById('batchDetailTitle')!.textContent = batchName || 'Batch Items';
    document.getElementById('batchDetailModal')?.classList.remove('hidden');
    const tbody = document.getElementById('batchDetailTableBody')!;
    tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-6 text-center text-gray-400">Loading…</td></tr>';

    const resp = await fetch(`/api/order-items?batch_id=${batchId}`);
    if (!resp.ok) {
      tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-6 text-center text-red-400">Failed to load items.</td></tr>';
      return;
    }
    const { data } = await resp.json();
    allBatchItems = data || [];
    activeTab = 'all';
    window.switchTab('all');
  };

  (window as any).switchTab = (tab: string) => {
    activeTab = tab;
    ['all', 'matched', 'missing'].forEach(t => {
      const btn = document.getElementById(`tab${t.charAt(0).toUpperCase() + t.slice(1)}`)!;
      btn.className = t === tab
        ? 'px-3 py-1 text-sm rounded-full bg-purple-600 text-white'
        : 'px-3 py-1 text-sm rounded-full bg-gray-700 text-gray-300 hover:bg-gray-600';
    });
    renderBatchItems();
  };

  function renderBatchItems() {
    const items = activeTab === 'all' ? allBatchItems
      : allBatchItems.filter(i => i.match_status === activeTab);

    const matched = allBatchItems.filter(i => i.match_status === 'matched').length;
    const missing = allBatchItems.filter(i => i.match_status === 'missing').length;
    const totalValue = allBatchItems.reduce((s: number, i: any) => s + (Number(i.provider_cost) || 0), 0);

    document.getElementById('detailTotal')!.textContent = String(allBatchItems.length);
    document.getElementById('detailMatched')!.textContent = String(matched);
    document.getElementById('detailMissing')!.textContent = String(missing);
    document.getElementById('detailValue')!.textContent = `$${totalValue.toFixed(2)}`;

    const tbody = document.getElementById('batchDetailTableBody')!;
    if (items.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="px-4 py-6 text-center text-gray-400">No items in this view.</td></tr>';
      return;
    }

    tbody.innerHTML = items.map((item: any) => `
      <tr class="border-b border-gray-700/50 hover:bg-gray-700/20">
        <td class="px-3 py-2 text-white font-mono text-xs">${item.barcode}</td>
        <td class="px-3 py-2 text-gray-300 truncate max-w-xs">${item.title || '-'}</td>
        <td class="px-3 py-2 text-gray-400 text-xs">${item.company?.name || '-'}</td>
        <td class="px-3 py-2 text-right text-white">${item.order_qty}</td>
        <td class="px-3 py-2 text-right text-white">$${Number(item.amazon_cost).toFixed(2)}</td>
        <td class="px-3 py-2 text-right text-white">$${Number(item.provider_cost).toFixed(2)}</td>
        <td class="px-3 py-2 text-right ${
          item.profit_loss > 0 ? 'text-green-400' : item.profit_loss < 0 ? 'text-red-400' : 'text-gray-400'
        }">${Number(item.profit_loss).toFixed(2)} (${Number(item.profit_loss_pct).toFixed(1)}%)</td>
        <td class="px-3 py-2 text-center">
          <span class="px-2 py-0.5 text-xs rounded-full ${
            item.match_status === 'matched' ? 'bg-green-900/30 text-green-300' : 'bg-red-900/30 text-red-400'
          }">${item.match_status}</span>
        </td>
      </tr>
    `).join('');
  }

  document.getElementById('closeBatchDetail')?.addEventListener('click', () => {
    document.getElementById('batchDetailModal')?.classList.add('hidden');
  });

  // Init
  loadBatches();
</script>
