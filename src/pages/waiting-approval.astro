---
import AuthLayout from '../layouts/AuthLayout.astro';
import { getCurrentUser } from '../lib/auth';

// Get current user to show personalized message
let user = null;
try {
  user = await getCurrentUser(Astro.request);
} catch (error) {
  console.error('Error getting user:', error);
}

// If user is approved, redirect to home
if (user?.profile?.status === 'approved') {
  return Astro.redirect('/');
}

// If no user or not pending, redirect to login
if (!user || user.profile?.status !== 'pending') {
  return Astro.redirect('/login');
}
---

<AuthLayout title="Waiting for Approval - KSA CRM">
  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">

      <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-8 shadow-modal backdrop-blur text-center">
        <!-- Pending approval icon -->
        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-2xl bg-yellow-500/10 border border-yellow-500/30 mb-6">
          <svg class="h-8 w-8 text-yellow-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="text-2xl font-bold tracking-tight text-white">Account Pending Approval</h1>

        <p class="mt-3 text-sm text-gray-400">
          Welcome, <span class="text-gray-200 font-medium">{user?.email}</span>! Your account has been created and is waiting for an administrator to approve it.
        </p>

        <div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 mt-6 text-left">
          <h3 class="text-sm font-semibold text-blue-300">What happens next?</h3>
          <ul class="mt-2 text-sm text-blue-200/80 list-disc list-inside space-y-1">
            <li>An administrator has been notified of your registration</li>
            <li>They will review your account and approve access</li>
            <li>You'll receive an email notification once approved</li>
            <li>After approval, you can sign in and access the system</li>
          </ul>
        </div>

        <div class="bg-gray-800/60 border border-gray-700/60 rounded-xl p-4 mt-4 text-left">
          <h3 class="text-sm font-semibold text-gray-200">Need help?</h3>
          <p class="mt-1 text-sm text-gray-400">
            If you have questions about your account or need urgent access, please contact your system administrator.
          </p>
        </div>

        <div class="mt-8 space-y-3">
          <button
            id="refreshButton"
            class="w-full flex justify-center items-center py-2.5 px-4 rounded-xl text-sm font-semibold text-purple-300 border border-purple-500/40 bg-purple-500/10 hover:bg-purple-500/20 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-900 focus:ring-purple-500 transition-colors"
          >
            <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Check Approval Status
          </button>

          <button
            id="logoutButton"
            class="w-full flex justify-center py-2.5 px-4 rounded-xl text-sm font-medium text-gray-300 border border-gray-700 bg-gray-800/60 hover:bg-gray-700/60 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-900 focus:ring-purple-500 transition-colors"
          >
            Sign Out
          </button>
        </div>

        <p class="mt-6 text-xs text-gray-500">
          Account created: {new Date(user?.profile?.created_at || '').toLocaleDateString()}
        </p>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  import { supabase } from '../lib/supabase';

  const refreshButton = document.getElementById('refreshButton') as HTMLButtonElement;
  const logoutButton = document.getElementById('logoutButton') as HTMLButtonElement;

  // Check approval status
  refreshButton.addEventListener('click', async () => {
    const originalText = refreshButton.textContent;
    refreshButton.textContent = 'Checking...';
    refreshButton.disabled = true;

    try {
      const { data: { user }, error } = await supabase.auth.getUser();

      if (error || !user) {
        window.location.href = '/login';
        return;
      }

      // Get updated profile
      const { data: profile, error: profileError } = await supabase
        .from('users_profile')
        .select('*')
        .eq('id', user.id)
        .single();

      if (profileError) {
        throw profileError;
      }

      if (profile.status === 'approved') {
        // Show success message and redirect
        refreshButton.textContent = 'Approved! Redirecting...';
        refreshButton.className = refreshButton.className
          .replace('text-purple-300', 'text-green-300')
          .replace('border-purple-500/40', 'border-green-500/40')
          .replace('bg-purple-500/10', 'bg-green-500/10');

        setTimeout(() => {
          window.location.href = '/';
        }, 1500);
      } else if (profile.status === 'suspended') {
        window.location.href = '/login?error=suspended';
      } else {
        // Still pending
        refreshButton.textContent = 'Still pending approval';
        setTimeout(() => {
          refreshButton.textContent = originalText;
        }, 2000);
      }
    } catch (error) {
      console.error('Error checking status:', error);
      refreshButton.textContent = 'Error checking status';
      setTimeout(() => {
        refreshButton.textContent = originalText;
      }, 2000);
    } finally {
      refreshButton.disabled = false;
    }
  });

  // Logout functionality
  logoutButton.addEventListener('click', async () => {
    try {
      await supabase.auth.signOut();
      window.location.href = '/login';
    } catch (error) {
      console.error('Error signing out:', error);
      // Force redirect even if logout fails
      window.location.href = '/login';
    }
  });

  // Auto-refresh every 30 seconds to check for approval
  let autoRefreshInterval = setInterval(async () => {
    try {
      const { data: { user }, error } = await supabase.auth.getUser();

      if (error || !user) {
        clearInterval(autoRefreshInterval);
        window.location.href = '/login';
        return;
      }

      const { data: profile } = await supabase
        .from('users_profile')
        .select('status')
        .eq('id', user.id)
        .single();

      if (profile?.status === 'approved') {
        clearInterval(autoRefreshInterval);
        window.location.href = '/';
      } else if (profile?.status === 'suspended') {
        clearInterval(autoRefreshInterval);
        window.location.href = '/login?error=suspended';
      }
    } catch (error) {
      console.error('Auto-refresh error:', error);
    }
  }, 30000); // Check every 30 seconds

  // Clean up interval when page is unloaded
  window.addEventListener('beforeunload', () => {
    clearInterval(autoRefreshInterval);
  });
</script>
