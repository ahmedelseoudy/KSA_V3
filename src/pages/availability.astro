---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import StatCard from '../components/ui/StatCard.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Availability Overview - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <PageHeader title="Availability Overview" subtitle="Track supplier availability responses and generate purchase orders from available items" />

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6" id="summaryCards">
      <StatCard label="Total Requests" valueId="totalRequests" />
      <StatCard label="Fully Responded" valueId="fullResponded" valueClass="text-green-400" />
      <StatCard label="Pending" valueId="pending" valueClass="text-yellow-400" />
      <StatCard label="Unavailable Items" valueId="unavailableCount" valueClass="text-red-400" />
    </div>

    <!-- Company Breakdown -->
    <div class="bg-gray-800/60 rounded-xl border border-gray-700/60 shadow-card mb-6">
      <div class="p-5 border-b border-gray-700/60">
        <h2 class="text-lg font-semibold text-white">Company Responses</h2>
      </div>
      <!-- Filters -->
      <div class="px-4 py-3 border-b border-gray-700/60 sticky top-0 z-20 bg-gray-900/90 backdrop-blur supports-[backdrop-filter]:bg-gray-900/80 rounded-t-none">
        <div class="flex flex-wrap items-stretch gap-x-6 gap-y-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Filters</p>
            <div class="flex flex-wrap items-end gap-3">
              <div>
                <label for="availCompanyFilter" class="block text-xs text-gray-500 mb-1">Company</label>
                <select id="availCompanyFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[12rem]">
                  <option value="all">All companies</option>
                </select>
              </div>
              <div>
                <label for="availStatusFilter" class="block text-xs text-gray-500 mb-1">Status</label>
                <select id="availStatusFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                  <option value="all">All</option>
                  <option value="responded">Responded</option>
                  <option value="partially_responded">Partially responded</option>
                  <option value="pending">Pending</option>
                </select>
              </div>
            </div>
          </div>
          <div class="hidden lg:block w-px self-stretch bg-gray-700/60" aria-hidden="true"></div>
          <div class="lg:ml-auto">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-2">Generate Purchase Orders</p>
            <div class="flex flex-wrap items-end gap-3">
              <div>
                <label class="block text-xs text-gray-500 mb-1">Batch</label>
                <select id="batchSelect" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[14rem]">
                  <option value="">Select a batch…</option>
                </select>
              </div>
              <div>
                <label class="block text-xs text-gray-500 mb-1">PO Reference</label>
                <input id="poNumberInput" type="text" placeholder="Auto from availability name (optional)" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[14rem]" />
              </div>
              <div>
                <label class="block text-xs text-gray-500 mb-1">Delivery Date</label>
                <input id="poDateInput" type="date" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[12rem]" />
              </div>
              <label class="inline-flex items-center gap-2 text-sm text-gray-300 py-2">
                <input id="includePartialChk" type="checkbox" class="accent-purple-600" /> Include partially responded
              </label>
              <button id="generatePOsBtn" class="btn btn-primary btn-md disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Generate POs
              </button>
            </div>
          </div>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="sticky top-0 z-10">
            <tr>
              <th class="px-3 py-3 text-left bg-gray-800/80 w-8"></th>
              <th data-avsort="company" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Company <span class="text-gray-500 sort" data-key="company"></span></th>
              <th data-avsort="total_items" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Total Items <span class="text-gray-500 sort" data-key="total_items"></span></th>
              <th data-avsort="available_count" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Available <span class="text-gray-500 sort" data-key="available_count"></span></th>
              <th data-avsort="unavailable_count" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Unavailable <span class="text-gray-500 sort" data-key="unavailable_count"></span></th>
              <th data-avsort="rate" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Rate <span class="text-gray-500 sort" data-key="rate"></span></th>
              <th data-avsort="status" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 cursor-pointer select-none">Status <span class="text-gray-500 sort" data-key="status"></span></th>
            </tr>
          </thead>
          <tbody id="companyTable">
            <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500 text-sm animate-pulse">Loading...</td></tr>
          </tbody>
        </table>
      </div>
      <div class="flex flex-col md:flex-row items-center justify-between gap-3 p-3 border-t border-gray-700/60 bg-gray-800/60 rounded-b-xl">
        <div class="flex items-center gap-2 text-sm text-gray-400">
          <label for="avPageSize">Rows per page</label>
          <select id="avPageSize" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
            <option value="10">10</option>
            <option value="20" selected>20</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <button id="avPrev" class="btn btn-secondary btn-sm disabled:opacity-50 disabled:cursor-not-allowed">Prev</button>
          <span id="avPageInfo" class="text-sm text-gray-400 tabular-nums">-</span>
          <button id="avNext" class="btn btn-secondary btn-sm disabled:opacity-50 disabled:cursor-not-allowed">Next</button>
        </div>
      </div>
    </div>

    <!-- Unavailable Items (cross-company) -->
    <div id="unavailableSection" class="bg-gray-800/60 rounded-xl border border-gray-700/60 shadow-card overflow-hidden">
      <div class="p-5 border-b border-gray-700/60 flex flex-wrap justify-between items-center gap-3">
        <h2 class="text-lg font-semibold text-white">Unavailable Items Summary</h2>
        <button id="downloadUnavailable" class="inline-flex items-center justify-center gap-2 px-4 py-2 text-red-300 bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
          Download Unavailable
        </button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Barcode</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Title</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Qty</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Companies Asked</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Unavailable From</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">All Unavailable?</th>
            </tr>
          </thead>
          <tbody id="unavailableTable">
            <tr><td colspan="6" class="px-4 py-8 text-center text-gray-500 text-sm animate-pulse">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  import * as XLSX from 'xlsx';

  let unavailableData: any[] = [];
  let allAvailOrders: any[] = [];
  let availCompanyFilter = 'all';
  let availStatusFilter = 'all';
  let allBatches: any[] = [];
  const urlParams = new URLSearchParams(window.location.search);
  const forcedBatchId = urlParams.get('batch_id') || '';

  function getFilteredOrders() {
    let rows = [...allAvailOrders];
    if (forcedBatchId) rows = rows.filter((o: any) => (o.batch_id || '') === forcedBatchId);
    if (availCompanyFilter !== 'all') rows = rows.filter((o: any) => (o.company?.id || null) === availCompanyFilter);
    if (availStatusFilter !== 'all') rows = rows.filter((o: any) => o.status === availStatusFilter);
    return rows;
  }

  async function loadAvailabilityData() {
    const resp = await fetch('/api/availability');
    if (!resp.ok) return;
    const { data } = await resp.json();
    
    const orders = data || [];
    allAvailOrders = orders;
    const total = orders.length;
    const responded = orders.filter((o: any) => o.status === 'responded').length;
    const pending = orders.filter((o: any) => o.status === 'pending' || o.status === 'partially_responded').length;

    document.getElementById('totalRequests')!.textContent = String(total);
    document.getElementById('fullResponded')!.textContent = String(responded);
    document.getElementById('pending')!.textContent = String(pending);

    // Build company filter options
    const sel = document.getElementById('availCompanyFilter');
    if (sel) {
      const opts = new Map();
      for (const o of orders) {
        const id = o.company?.id; const nm = o.company?.name;
        if (id && nm) opts.set(id, nm);
      }
      const prev = availCompanyFilter;
      sel.innerHTML = '<option value="all">All companies</option>' +
        Array.from(opts.entries()).sort((a,b)=>a[1].localeCompare(b[1]))
          .map(([id,name]) => `<option value="${id}">${name}</option>`).join('');
      if (prev !== 'all' && opts.has(prev)) { (sel as HTMLSelectElement).value = prev; }
    }

    renderCompanyTable();

    // Load unavailable items summary using current filters
    await loadUnavailableItems(getFilteredOrders());
  }

  async function loadBatches() {
    const resp = await fetch('/api/orders?limit=200');
    if (!resp.ok) return;
    const { data } = await resp.json();
    allBatches = data || [];
    const sel = document.getElementById('batchSelect') as HTMLSelectElement | null;
    if (!sel) return;
    sel.innerHTML = '<option value="">Select a batch…</option>' +
      allBatches.map((b: any) => `<option value="${b.id}">${b.name || b.id}</option>`).join('');
    updateGenerateBtnState();
  }

  function updateGenerateBtnState() {
    const batchId = (document.getElementById('batchSelect') as HTMLSelectElement)?.value || '';
    const btn = document.getElementById('generatePOsBtn') as HTMLButtonElement | null;
    if (btn) btn.disabled = !batchId;
  }

  function renderCompanyTable() {
    // Initialize state and re-render using sorting+paging
    (window as any).__AV_STATE__ = (window as any).__AV_STATE__ || { sortKey: 'company', sortDir: 'asc', page: 1, pageSize: 20 };
    applyAvSortingPaging();
  }

  function renderCompanyTableRows(rows: any[]) {
    const tbody = document.getElementById('companyTable');
    if (!tbody) return;
    if (!rows || rows.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="py-12 text-center text-gray-400 text-sm">No availability orders yet.</td></tr>';
      return;
    }
    tbody.innerHTML = rows.map((o: any) => {
      const rate = o.total_items > 0 ? ((o.available_count / o.total_items) * 100).toFixed(0) : '0';
      return `
        <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors group" data-row="${o.id}">
          <td class="px-3 py-3 align-top">
            <button class="expand-btn w-6 h-6 inline-flex items-center justify-center rounded-md bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 hover:text-white text-xs transition-colors" aria-expanded="false" aria-controls="details-${o.id}" data-id="${o.id}">+</button>
          </td>
          <td class="px-4 py-3 text-white font-medium">${o.company?.name || 'Unknown'}</td>
          <td class="px-4 py-3 text-right text-white tabular-nums">${o.total_items}</td>
          <td class="px-4 py-3 text-right text-green-400 tabular-nums">${o.available_count || 0}</td>
          <td class="px-4 py-3 text-right text-red-400 tabular-nums">${o.unavailable_count || 0}</td>
          <td class="px-4 py-3 text-right text-white tabular-nums">${rate}%</td>
          <td class="px-4 py-3 text-center">
            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ring-1 ring-inset ${
              o.status === 'responded' ? 'bg-green-500/10 text-green-300 ring-green-500/30' :
              o.status === 'partially_responded' ? 'bg-yellow-500/10 text-yellow-300 ring-yellow-500/30' :
              'bg-gray-500/10 text-gray-300 ring-gray-500/30'
            }">${o.status.replace(/_/g, ' ')}</span>
          </td>
        </tr>
        <tr id="details-${o.id}" class="hidden border-t border-gray-700/40 bg-gray-900/40" data-loaded="false">
          <td></td>
          <td class="px-4 py-4" colspan="6">
            <div class="text-gray-400 text-sm" id="details-content-${o.id}"><span class="text-gray-500 text-sm animate-pulse">Loading details...</span></div>
          </td>
        </tr>
      `;
    }).join('');

    // Attach expand/collapse handlers
    const btns = tbody.querySelectorAll('.expand-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
        const row = document.getElementById(`details-${id}`)!;
        const btnEl = e.currentTarget as HTMLButtonElement;
        const expanded = btnEl.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          btnEl.setAttribute('aria-expanded', 'false');
          btnEl.textContent = '+';
          row.classList.add('hidden');
          return;
        }

        btnEl.setAttribute('aria-expanded', 'true');
        btnEl.textContent = '−';
        row.classList.remove('hidden');

        if (row.getAttribute('data-loaded') !== 'true') {
          await loadCompanyDetails(id);
          row.setAttribute('data-loaded', 'true');
        }
      });
    });
  }

  function avGetSortValue(o: any, key: string) {
    switch (key) {
      case 'company': return (o.company?.name || '').toString();
      case 'total_items': return Number(o.total_items || 0);
      case 'available_count': return Number(o.available_count || 0);
      case 'unavailable_count': return Number(o.unavailable_count || 0);
      case 'rate': {
        const t = Number(o.total_items || 0); const a = Number(o.available_count || 0);
        return t > 0 ? (a / t) : 0;
      }
      case 'status': return (o.status || '').toString();
      default: return '';
    }
  }

  function applyAvSortingPaging() {
    const st = (window as any).__AV_STATE__ || ((window as any).__AV_STATE__ = { sortKey: 'company', sortDir: 'asc', page: 1, pageSize: 20 });
    const { sortKey, sortDir, page, pageSize } = st;
    // Update header indicators based on current sort state
    document.querySelectorAll('thead .sort').forEach((el) => (el.textContent = ''));
    const cur = document.querySelector(`thead .sort[data-key="${sortKey}"]`);
    if (cur) cur.textContent = sortDir === 'asc' ? '▲' : '▼';
    let rows = getFilteredOrders();
    const sorted = [...rows].sort((a: any, b: any) => {
      const va = avGetSortValue(a, sortKey); const vb = avGetSortValue(b, sortKey);
      if (va < vb) return sortDir === 'asc' ? -1 : 1;
      if (va > vb) return sortDir === 'asc' ? 1 : -1;
      return 0;
    });
    const start = (page - 1) * pageSize;
    const pageRows = sorted.slice(start, start + pageSize);
    renderCompanyTableRows(pageRows);
    const total = sorted.length;
    const pageCount = Math.max(1, Math.ceil(total / pageSize));
    const info = document.getElementById('avPageInfo');
    if (info) info.textContent = `Page ${page} of ${pageCount}`;
    const prev = document.getElementById('avPrev') as HTMLButtonElement | null;
    const next = document.getElementById('avNext') as HTMLButtonElement | null;
    if (prev) prev.disabled = page <= 1;
    if (next) next.disabled = page >= pageCount;
  }

  function avWireSortHandlers() {
    const headers = document.querySelectorAll('th[data-avsort]');
    headers.forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.getAttribute('data-avsort') || 'company';
        const st = (window as any).__AV_STATE__ || ((window as any).__AV_STATE__ = { sortKey: 'company', sortDir: 'asc', page: 1, pageSize: 20 });
        if (st.sortKey === key) {
          st.sortDir = st.sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          st.sortKey = key; st.sortDir = 'asc';
        }
        st.page = 1;
        document.querySelectorAll('thead .sort').forEach((el) => (el.textContent = ''));
        const span = document.querySelector(`thead .sort[data-key="${key}"]`);
        if (span) span.textContent = st.sortDir === 'asc' ? '▲' : '▼';
        applyAvSortingPaging();
      });
    });
  }

  function avWirePagingHandlers() {
    const prev = document.getElementById('avPrev');
    const next = document.getElementById('avNext');
    const size = document.getElementById('avPageSize') as HTMLSelectElement | null;
    prev?.addEventListener('click', () => { const st = (window as any).__AV_STATE__; st.page = Math.max(1, st.page - 1); applyAvSortingPaging(); });
    next?.addEventListener('click', () => { const st = (window as any).__AV_STATE__; st.page = st.page + 1; applyAvSortingPaging(); });
    size?.addEventListener('change', () => { const st = (window as any).__AV_STATE__; st.pageSize = Number(size.value || '20') || 20; st.page = 1; applyAvSortingPaging(); });
  }

  async function loadCompanyDetails(availabilityOrderId: string) {
    const target = document.getElementById(`details-content-${availabilityOrderId}`);
    if (!target) return;
    try {
      const resp = await fetch(`/api/availability?id=${availabilityOrderId}`);
      if (!resp.ok) { target.textContent = 'Failed to load details.'; return; }
      const { data } = await resp.json();
      const items = Array.isArray(data) ? data : [];
      const available = items.filter((r: any) => r.is_available === true);
      const unavailable = items.filter((r: any) => r.is_available === false);

      const today = new Date().toISOString().slice(0,10);
      const actionBar = `
        <div class="flex flex-wrap items-end gap-3 mb-4 bg-gray-800/60 border border-gray-700/60 rounded-xl p-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">PO Reference</label>
            <input id="poInput-${availabilityOrderId}" type="text" placeholder="Auto from availability name (optional)" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-xs placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[14rem]" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Delivery Date</label>
            <input id="poDate-${availabilityOrderId}" type="date" value="${today}" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-xs focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[12rem]" />
          </div>
          <button id="poBtn-${availabilityOrderId}" class="btn btn-primary btn-sm">Create PO from available</button>
          <span class="text-xs text-gray-500 pb-1.5">Only items marked available will be included.</span>
        </div>
      `;

      const renderItemRow = (r: any) => {
        const it = r.order_item || {};
        const qty = typeof it.order_qty === 'number' ? it.order_qty : (it.order_qty || '');
        const boxes = typeof it.boxes === 'number' ? it.boxes : (it.boxes || '');
        const cost = typeof it.provider_cost === 'number' ? it.provider_cost : (it.provider_cost || '');
        return `
          <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors">
            <td class="px-3 py-2 font-mono text-xs text-gray-200">${it.barcode || '-'}</td>
            <td class="px-3 py-2 text-gray-100">${it.title || '-'}</td>
            <td class="px-3 py-2 text-gray-300">${it.asin || '-'}</td>
            <td class="px-3 py-2 text-right text-gray-200 tabular-nums">${qty || '-'}</td>
            <td class="px-3 py-2 text-right text-gray-200 tabular-nums">${boxes || '-'}</td>
            <td class="px-3 py-2 text-right text-gray-200 tabular-nums">${cost || '-'}</td>
            <td class="px-3 py-2 text-gray-300">${r.comment ? String(r.comment) : '-'}</td>
          </tr>
        `;
      };

      const section = (title: string, arr: any[]) => `
        <div class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-white font-semibold">${title} <span class="text-xs font-normal text-gray-400 tabular-nums">(${arr.length})</span></h3>
          </div>
          ${arr.length === 0 ? '<div class="text-sm text-gray-500">No items.</div>' : `
            <div class="overflow-x-auto rounded-lg border border-gray-700/40 bg-gray-800/40">
              <table class="w-full text-xs">
                <thead>
                  <tr>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Barcode</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Title</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">ASIN</th>
                    <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Order Qty</th>
                    <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Boxes</th>
                    <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Provider Cost</th>
                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Comment</th>
                  </tr>
                </thead>
                <tbody>
                  ${arr.map(renderItemRow).join('')}
                </tbody>
              </table>
            </div>
          `}
        </div>
      `;

      target.innerHTML = `
        ${actionBar}
        ${section('Available Items', available)}
        ${section('Unavailable Items', unavailable)}
      `;

      const poBtn = document.getElementById(`poBtn-${availabilityOrderId}`) as HTMLButtonElement | null;
      const poInp = document.getElementById(`poInput-${availabilityOrderId}`) as HTMLInputElement | null;
      const poDate = document.getElementById(`poDate-${availabilityOrderId}`) as HTMLInputElement | null;
      poBtn?.addEventListener('click', async () => {
        const poRef = (poInp?.value || '').trim();
        const deliveryDate = (poDate?.value || '').trim();
        try {
          const res = await fetch('/api/purchase-orders', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'generate', availability_order_ids: [availabilityOrderId], po_number: poRef || undefined, delivery_date: deliveryDate || undefined })
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(json.error || 'Failed to create PO');
          alert('PO created and email sent (if configured). View it in Purchase Orders.');
        } catch (e: any) {
          alert('Error: ' + ((e && e.message) || 'Failed to create PO'));
        }
      });
    } catch (e: any) {
      target.textContent = 'Error loading details.';
    }
  }

  // Filter listeners
  document.getElementById('availCompanyFilter')?.addEventListener('change', async (e) => {
    const v = (e.target as HTMLSelectElement).value || 'all';
    availCompanyFilter = v;
    // Re-render via sorting+paging pipeline
    const st = (window as any).__AV_STATE__ || ((window as any).__AV_STATE__ = { sortKey: 'company', sortDir: 'asc', page: 1, pageSize: 20 });
    st.page = 1;
    applyAvSortingPaging();
    await loadUnavailableItems(getFilteredOrders());
  });
  document.getElementById('availStatusFilter')?.addEventListener('change', async (e) => {
    const v = (e.target as HTMLSelectElement).value || 'all';
    availStatusFilter = v;
    const st = (window as any).__AV_STATE__ || ((window as any).__AV_STATE__ = { sortKey: 'company', sortDir: 'asc', page: 1, pageSize: 20 });
    st.page = 1;
    applyAvSortingPaging();
    await loadUnavailableItems(getFilteredOrders());
  });

  // Batch-level Generate POs
  document.getElementById('batchSelect')?.addEventListener('change', updateGenerateBtnState);
  document.getElementById('poNumberInput')?.addEventListener('input', updateGenerateBtnState);
  document.getElementById('generatePOsBtn')?.addEventListener('click', async () => {
    const batchId = (document.getElementById('batchSelect') as HTMLSelectElement)?.value || '';
    const poNum = (document.getElementById('poNumberInput') as HTMLInputElement)?.value?.trim() || '';
    const poDate = (document.getElementById('poDateInput') as HTMLInputElement)?.value?.trim() || '';
    const includePartial = (document.getElementById('includePartialChk') as HTMLInputElement)?.checked || false;
    if (!batchId) return;
    try {
      const res = await fetch('/api/purchase-orders', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'generate', batch_id: batchId, po_number: poNum || undefined, include_partial: includePartial, delivery_date: poDate || undefined })
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(json.error || 'Failed to generate POs');
      alert(`Created ${json.created || 0} PO(s). Emails sent: ${json.emails_sent || 0}.`);
    } catch (e: any) {
      alert('Error: ' + ((e && e.message) || 'Failed to generate POs'));
    }
  });

  async function loadUnavailableItems(orders: any[]) {
    const section = document.getElementById('unavailableSection');
    const tbody = document.getElementById('unavailableTable');
    const countEl = document.getElementById('unavailableCount');
    const downloadBtn = document.getElementById('downloadUnavailable') as HTMLButtonElement | null;

    // Decide visibility based on filters and orders
    const showSummary = (
      availCompanyFilter === 'all' ||
      availStatusFilter === 'responded' ||
      (availCompanyFilter !== 'all' && Array.isArray(orders) && orders.length > 0 && orders.every((o: any) => o.status === 'responded'))
    );

    if (!showSummary) {
      section?.classList.add('hidden');
      if (tbody) tbody.innerHTML = '<tr><td colspan="6" class="py-12 text-center text-gray-400 text-sm">Unavailable summary hidden for current filters</td></tr>';
      if (countEl) countEl.textContent = '0';
      if (downloadBtn) downloadBtn.disabled = true;
      return;
    }

    section?.classList.remove('hidden');
    unavailableData = [];
    const itemMap = new Map<string, any>();

    for (const ao of orders) {
      if (ao.status === 'pending') continue;

      const resp = await fetch(`/api/availability?id=${ao.id}`);
      if (!resp.ok) continue;
      const { data } = await resp.json();

      for (const r of data || []) {
        if (r.is_available === false) {
          const barcode = r.order_item?.barcode || 'unknown';
          if (!itemMap.has(barcode)) {
            itemMap.set(barcode, {
              barcode,
              title: r.order_item?.title || '-',
              order_qty: r.order_item?.order_qty || 0,
              companies_asked: [],
              companies_unavailable: [],
            });
          }
          const item = itemMap.get(barcode)!;
          const companyName = ao.company?.name || 'Unknown';
          if (!item.companies_unavailable.includes(companyName)) {
            item.companies_unavailable.push(companyName);
          }
        }

        // Track all companies asked
        const barcode = r.order_item?.barcode || 'unknown';
        if (!itemMap.has(barcode)) {
          itemMap.set(barcode, {
            barcode,
            title: r.order_item?.title || '-',
            order_qty: r.order_item?.order_qty || 0,
            companies_asked: [],
            companies_unavailable: [],
          });
        }
        const item = itemMap.get(barcode)!;
        const companyName = ao.company?.name || 'Unknown';
        if (!item.companies_asked.includes(companyName)) {
          item.companies_asked.push(companyName);
        }
      }
    }

    // Filter to only items with at least one unavailable
    unavailableData = Array.from(itemMap.values()).filter(i => i.companies_unavailable.length > 0);
    
    if (countEl) countEl.textContent = String(unavailableData.length);

    if (tbody) {
      if (unavailableData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="py-12 text-center text-gray-400 text-sm">No unavailable items found.</td></tr>';
      } else {
        tbody.innerHTML = unavailableData.map(item => {
          const allUnavailable = item.companies_unavailable.length === item.companies_asked.length;
          return `
            <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors ${allUnavailable ? 'bg-red-500/5' : ''}">
              <td class="px-4 py-3 text-white font-mono text-xs">${item.barcode}</td>
              <td class="px-4 py-3 text-white truncate max-w-xs">${item.title}</td>
              <td class="px-4 py-3 text-right text-white tabular-nums">${item.order_qty}</td>
              <td class="px-4 py-3 text-gray-300 text-xs">${item.companies_asked.join(', ')}</td>
              <td class="px-4 py-3 text-red-400 text-xs">${item.companies_unavailable.join(', ')}</td>
              <td class="px-4 py-3 text-center">
                ${allUnavailable ? '<span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-red-500/10 text-red-300 ring-1 ring-inset ring-red-500/30">Yes</span>' : '<span class="text-gray-400 text-xs">No</span>'}
              </td>
            </tr>
          `;
        }).join('');
      }

      if (downloadBtn) downloadBtn.disabled = unavailableData.length === 0;
    }
  }

  // Sanitize a sheet name (Excel max 31 chars, no : \ / ? * [ ])
  function safeSheetName(name: string): string {
    return String(name).replace(/[:\\/?*\[\]]/g, '_').slice(0, 31) || 'Sheet';
  }

  // Download unavailable items as a two-sheet Excel: per-item summary + one tab per company.
  document.getElementById('downloadUnavailable')?.addEventListener('click', () => {
    if (unavailableData.length === 0) return;

    const wb = XLSX.utils.book_new();

    // Sheet 1: per-item summary across all companies.
    const summaryRows = [
      ['Barcode', 'Title', 'Order Qty', '# Companies Asked', '# Unavailable', 'Unavailable From', 'Still Available From', 'All Unavailable'],
      ...unavailableData.map((item) => {
        const stillAvailable = item.companies_asked.filter((c: string) => !item.companies_unavailable.includes(c));
        return [
          item.barcode,
          item.title,
          item.order_qty,
          item.companies_asked.length,
          item.companies_unavailable.length,
          item.companies_unavailable.join(', '),
          stillAvailable.join(', '),
          item.companies_unavailable.length === item.companies_asked.length ? 'YES' : 'NO',
        ];
      }),
    ];
    const summaryWs = XLSX.utils.aoa_to_sheet(summaryRows);
    summaryWs['!cols'] = [
      { wch: 15 }, { wch: 40 }, { wch: 10 }, { wch: 18 }, { wch: 14 },
      { wch: 30 }, { wch: 30 }, { wch: 16 },
    ];
    XLSX.utils.book_append_sheet(wb, summaryWs, 'Summary');

    // Sheets 2..N: one per company, listing items they marked unavailable.
    const perCompany = new Map<string, any[]>();
    for (const item of unavailableData) {
      for (const company of item.companies_unavailable) {
        if (!perCompany.has(company)) perCompany.set(company, []);
        perCompany.get(company)!.push(item);
      }
    }
    const sortedCompanies = Array.from(perCompany.keys()).sort();
    for (const company of sortedCompanies) {
      const rows = [
        ['Barcode', 'Title', 'Order Qty'],
        ...perCompany.get(company)!.map((item) => [item.barcode, item.title, item.order_qty]),
      ];
      const ws = XLSX.utils.aoa_to_sheet(rows);
      ws['!cols'] = [{ wch: 15 }, { wch: 40 }, { wch: 10 }];
      XLSX.utils.book_append_sheet(wb, ws, safeSheetName(company));
    }

    XLSX.writeFile(wb, `Unavailable_Items_${new Date().toISOString().split('T')[0]}.xlsx`);
  });

  // Wire sorting/paging once DOM is ready
  document.addEventListener('DOMContentLoaded', () => { avWireSortHandlers(); avWirePagingHandlers(); });
  loadBatches().finally(loadAvailabilityData);
</script>
