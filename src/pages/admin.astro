---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import StatCard from '../components/ui/StatCard.astro';

// Agent A Fix — BUG-002: Use Astro.locals.user (set by middleware via server-side cookies)
// Previously used getCurrentUser(Astro.request) which calls the browser/client-side SDK
// and always returns null during SSR (no localStorage on server)
const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!user || !profile) {
  return Astro.redirect('/login');
}

if (profile.status !== 'approved') {
  return Astro.redirect('/waiting-approval');
}

if (!['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}

const isSuper = profile.role === 'super_admin';
---

<Layout title="Admin Panel - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <PageHeader title="Admin Panel" subtitle="Manage users, roles, and system settings">
      <div slot="actions" class="flex items-center gap-2 flex-wrap">
        <button
          id="refreshDataButton"
          class="btn btn-secondary btn-md"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"></path>
          </svg>
          Refresh
        </button>
        {isSuper && (
          <button
            id="createAdminButton"
            class="btn btn-secondary btn-md"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 8a6 6 0 01-7.743 5.743L10 14l-1 1-1 1H6v2H2v-4l4.257-4.257A6 6 0 1118 8zm-6-4a1 1 0 100 2 2 2 0 012 2 1 1 0 102 0 4 4 0 00-4-4z" clip-rule="evenodd"></path>
            </svg>
            Create Admin
          </button>
        )}
        <button
          id="inviteUserButton"
          class="btn btn-primary btn-md"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"></path>
          </svg>
          Invite User
        </button>
      </div>
    </PageHeader>

    <main>
      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <StatCard label="Approved Users" valueId="approvedCount" valueClass="text-green-400" />
        <StatCard label="Pending Approval" valueId="pendingCount" valueClass="text-yellow-400" />
        <StatCard label="Total Users" valueId="totalCount" valueClass="text-white" />
        <StatCard label="Admins" valueId="adminCount" valueClass="text-purple-400" />
      </div>

      <!-- Users Table -->
      <div class="bg-gray-800/60 rounded-xl border border-gray-700/60 shadow-card">
        <div class="p-5">
          <div class="flex flex-wrap justify-between items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold text-white">User Management</h3>
            <div class="flex flex-wrap items-center gap-2">
              <select id="statusFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                <option value="">All Status</option>
                <option value="pending">Pending</option>
                <option value="approved">Approved</option>
                <option value="suspended">Suspended</option>
              </select>
              <select id="roleFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                <option value="">All Roles</option>
                <option value="user">User</option>
                <option value="admin">Admin</option>
                <option value="super_admin">Super Admin</option>
              </select>
            </div>
          </div>

          <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
            <table class="w-full text-sm">
              <thead>
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">User</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Role</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Created</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Actions</th>
                </tr>
              </thead>
              <tbody id="usersTableBody">
                <!-- Users will be loaded here -->
              </tbody>
            </table>
          </div>

          <div id="loadingMessage" class="text-center py-8 text-gray-500 text-sm animate-pulse">
            Loading users...
          </div>

          <div id="noUsersMessage" class="text-center py-12 text-gray-400 text-sm hidden">
            No users found.
          </div>
        </div>
      </div>
    </main>

    <!-- Invite User Modal -->
    <div id="inviteModal" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm overflow-y-auto h-full w-full hidden">
      <div class="relative top-20 mx-auto w-96 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-2xl shadow-modal">
        <div class="p-6">
          <h3 class="text-lg font-semibold text-white mb-4">Invite New User</h3>
          <form id="inviteForm">
            <div class="mb-6">
              <label for="inviteEmail" class="block text-sm font-medium text-gray-300 mb-1.5">Email Address</label>
              <input
                type="email"
                id="inviteEmail"
                required
                class="block w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                placeholder="user@example.com"
              />
            </div>
            <div class="flex justify-end gap-3">
              <button
                type="button"
                id="cancelInvite"
                class="btn btn-secondary btn-md"
              >
                Cancel
              </button>
              <button
                type="submit"
                class="btn btn-primary btn-md"
              >
                Send Invite
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Create Admin Modal -->
    {isSuper && (
      <div id="createAdminModal" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm overflow-y-auto h-full w-full hidden">
        <div class="relative top-20 mx-auto w-96 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-2xl shadow-modal">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-white mb-4">Create Admin</h3>
            <form id="createAdminForm">
              <div class="mb-6">
                <label for="createAdminEmail" class="block text-sm font-medium text-gray-300 mb-1.5">Email Address</label>
                <input
                  type="email"
                  id="createAdminEmail"
                  required
                  class="block w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                  placeholder="admin@example.com"
                />
                <p class="mt-1.5 text-xs text-gray-500">A temporary password is generated and emailed to them. They'll be approved with admin access immediately.</p>
              </div>
              <div class="flex justify-end gap-3">
                <button
                  type="button"
                  id="cancelCreateAdmin"
                  class="btn btn-secondary btn-md"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  id="submitCreateAdmin"
                  class="btn btn-primary btn-md"
                >
                  Create Admin
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    )}
  </div>

<script define:vars={{ currentUserId: profile?.id, isSuperAdmin: isSuper }}>
  // Global state
  let users = [];
  let filteredUsers = [];
  const currentUser = currentUserId;
  const isSuper = isSuperAdmin;

  // DOM elements
  const usersTableBody = document.getElementById('usersTableBody');
  const loadingMessage = document.getElementById('loadingMessage');
  const noUsersMessage = document.getElementById('noUsersMessage');
  const statusFilter = document.getElementById('statusFilter');
  const roleFilter = document.getElementById('roleFilter');
  const inviteModal = document.getElementById('inviteModal');
  const inviteForm = document.getElementById('inviteForm');
  const inviteEmail = document.getElementById('inviteEmail');
  const createAdminModal = document.getElementById('createAdminModal');
  const createAdminForm = document.getElementById('createAdminForm');
  const createAdminEmail = document.getElementById('createAdminEmail');
  const submitCreateAdmin = document.getElementById('submitCreateAdmin');

  // Load and display users via server-side API
  async function loadUsers() {
    try {
      loadingMessage.classList.remove('hidden');
      usersTableBody.innerHTML = '';

      const resp = await fetch('/api/users');
      if (!resp.ok) {
        const err = await resp.json().catch(() => ({}));
        throw new Error(err.error || 'API error ' + resp.status);
      }
      const { data } = await resp.json();

      users = data || [];
      updateStats();
      applyFilters();
    } catch (error) {
      console.error('Error loading users:', error);
      showNotification('Error loading users: ' + error.message, 'error');
    } finally {
      loadingMessage.classList.add('hidden');
    }
  }

  function updateStats() {
    const approved = users.filter(u => u.status === 'approved').length;
    const pending = users.filter(u => u.status === 'pending').length;
    const admins = users.filter(u => ['admin', 'super_admin'].includes(u.role)).length;
    document.getElementById('approvedCount').textContent = String(approved);
    document.getElementById('pendingCount').textContent = String(pending);
    document.getElementById('totalCount').textContent = String(users.length);
    document.getElementById('adminCount').textContent = String(admins);
  }

  function applyFilters() {
    const sv = statusFilter.value;
    const rv = roleFilter.value;
    filteredUsers = users.filter(u => (!sv || u.status === sv) && (!rv || u.role === rv));
    renderUsers();
  }

  function renderUsers() {
    if (filteredUsers.length === 0) {
      usersTableBody.innerHTML = '';
      noUsersMessage.classList.remove('hidden');
      return;
    }
    noUsersMessage.classList.add('hidden');
    usersTableBody.innerHTML = filteredUsers.map(user => `
      <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors">
        <td class="px-4 py-3 whitespace-nowrap">
          <div class="text-sm font-medium text-white">${user.email}</div>
          <div class="text-xs text-gray-500">ID: ${user.id.substring(0, 8)}...</div>
        </td>
        <td class="px-4 py-3 whitespace-nowrap">
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${getRoleBadge(user.role)}">
            ${user.role.replace('_', ' ')}
          </span>
        </td>
        <td class="px-4 py-3 whitespace-nowrap">
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${getStatusBadge(user.status)}">
            ${user.status}
          </span>
        </td>
        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-400">
          ${new Date(user.created_at).toLocaleDateString()}
        </td>
        <td class="px-4 py-3 whitespace-nowrap text-sm font-medium">
          ${getActions(user)}
        </td>
      </tr>
    `).join('');
    addActionListeners();
  }

  function getRoleBadge(role) {
    if (role === 'super_admin') return 'bg-purple-500/10 text-purple-300 ring-1 ring-inset ring-purple-500/30';
    if (role === 'admin') return 'bg-blue-500/10 text-blue-300 ring-1 ring-inset ring-blue-500/30';
    if (role === 'unknown') return 'bg-orange-500/10 text-orange-300 ring-1 ring-inset ring-orange-500/30';
    return 'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30';
  }

  function getStatusBadge(status) {
    if (status === 'approved') return 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30';
    if (status === 'pending') return 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30';
    if (status === 'suspended') return 'bg-red-500/10 text-red-300 ring-1 ring-inset ring-red-500/30';
    if (status === 'orphaned') return 'bg-orange-500/10 text-orange-300 ring-1 ring-inset ring-orange-500/30';
    return 'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30';
  }

  function getActions(user) {
    if (user.id === currentUser) return '<span class="text-gray-500 text-xs">Current User</span>';
    let b = '';
    const canDelete = isSuper || user.role !== 'super_admin';
    if (user.status === 'orphaned') {
      if (!isSuper) return '<span class="text-gray-500 text-xs">No actions</span>';
      return `<button onclick="window.rejectUser('${user.id}')" class="text-red-400 hover:text-red-300 mr-3 text-xs font-medium transition-colors">Delete</button>`;
    }
    if (user.status === 'pending') {
      b += `<button onclick="window.approveUser('${user.id}')" class="text-green-400 hover:text-green-300 mr-3 text-xs font-medium transition-colors">Approve</button>`;
      b += `<button onclick="window.rejectUser('${user.id}')" class="text-red-400 hover:text-red-300 mr-3 text-xs font-medium transition-colors">Reject</button>`;
    }
    if (user.status === 'approved') {
      b += `<button onclick="window.suspendUser('${user.id}')" class="text-red-400 hover:text-red-300 mr-3 text-xs font-medium transition-colors">Suspend</button>`;
      if (canDelete) b += `<button onclick="window.rejectUser('${user.id}')" class="text-red-400 hover:text-red-300 mr-3 text-xs font-medium transition-colors">Delete</button>`;
    } else if (user.status === 'suspended') {
      b += `<button onclick="window.unsuspendUser('${user.id}')" class="text-green-400 hover:text-green-300 mr-3 text-xs font-medium transition-colors">Unsuspend</button>`;
      if (canDelete) b += `<button onclick="window.rejectUser('${user.id}')" class="text-red-400 hover:text-red-300 mr-3 text-xs font-medium transition-colors">Delete</button>`;
    }
    if (isSuper && user.role !== 'super_admin') {
      if (user.role === 'user') b += `<button onclick="window.promoteToAdmin('${user.id}')" class="text-blue-400 hover:text-blue-300 mr-3 text-xs font-medium transition-colors">Make Admin</button>`;
      else if (user.role === 'admin') b += `<button onclick="window.demoteToUser('${user.id}')" class="text-orange-400 hover:text-orange-300 mr-3 text-xs font-medium transition-colors">Remove Admin</button>`;
    }
    return b || '<span class="text-gray-500 text-xs">No actions</span>';
  }

  function addActionListeners() {
    window.approveUser = approveUser;
    window.rejectUser = rejectUser;
    window.suspendUser = suspendUser;
    window.unsuspendUser = unsuspendUser;
    window.promoteToAdmin = promoteToAdmin;
    window.demoteToUser = demoteToUser;
  }

  async function updateUser(userId, updates) {
    const resp = await fetch('/api/users', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, updates }),
    });
    if (!resp.ok) {
      const err = await resp.json().catch(() => ({}));
      throw new Error(err.error || 'Update failed');
    }
  }

  async function approveUser(userId) {
    try {
      await updateUser(userId, { status: 'approved', approved_by: currentUser, approved_at: new Date().toISOString() });
      showNotification('User approved', 'success');
      loadUsers();
    } catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  async function rejectUser(userId) {
    if (!confirm('Delete this user profile?')) return;
    try {
      const resp = await fetch('/api/users?id=' + userId, { method: 'DELETE' });
      if (!resp.ok) throw new Error((await resp.json().catch(() => ({}))).error || 'Delete failed');
      showNotification('User removed', 'success');
      loadUsers();
    } catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  async function suspendUser(userId) {
    try { await updateUser(userId, { status: 'suspended' }); showNotification('User suspended', 'success'); loadUsers(); }
    catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  async function unsuspendUser(userId) {
    try { await updateUser(userId, { status: 'approved' }); showNotification('User unsuspended', 'success'); loadUsers(); }
    catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  async function promoteToAdmin(userId) {
    if (!confirm('Make this user an admin?')) return;
    try { await updateUser(userId, { role: 'admin' }); showNotification('Promoted to admin', 'success'); loadUsers(); }
    catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  async function demoteToUser(userId) {
    if (!confirm('Remove admin privileges?')) return;
    try { await updateUser(userId, { role: 'user' }); showNotification('Admin privileges removed', 'success'); loadUsers(); }
    catch (e) { showNotification('Error: ' + e.message, 'error'); }
  }

  function showNotification(message, type) {
    const n = document.createElement('div');
    n.className = 'fixed top-4 right-4 px-4 py-3 rounded-lg shadow-modal z-50 max-w-sm text-sm font-medium text-white ' +
      (type === 'success' ? 'bg-green-600' : 'bg-red-600');
    n.textContent = message;
    document.body.appendChild(n);
    setTimeout(() => n.remove(), 5000);
  }

  document.getElementById('refreshDataButton')?.addEventListener('click', loadUsers);

  document.getElementById('inviteUserButton')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = '/admin/invite';
  });

  document.getElementById('cancelInvite')?.addEventListener('click', () => {
    inviteModal.classList.add('hidden');
    inviteForm.reset();
  });

  document.getElementById('createAdminButton')?.addEventListener('click', () => {
    createAdminModal?.classList.remove('hidden');
  });

  document.getElementById('cancelCreateAdmin')?.addEventListener('click', () => {
    createAdminModal?.classList.add('hidden');
    createAdminForm?.reset();
  });

  createAdminModal?.addEventListener('click', (e) => {
    if (e.target === createAdminModal) { createAdminModal.classList.add('hidden'); createAdminForm?.reset(); }
  });

  createAdminForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = createAdminEmail.value.trim().toLowerCase();
    if (!email) return;
    submitCreateAdmin.disabled = true;
    submitCreateAdmin.textContent = 'Creating...';
    try {
      const resp = await fetch('/api/users', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const json = await resp.json().catch(() => ({}));
      if (!resp.ok || !json.success) throw new Error(json.error || 'Failed to create admin');

      createAdminModal.classList.add('hidden');
      createAdminForm.reset();
      showNotification(
        json.emailed
          ? `Admin created — an email with login instructions was sent to ${email}`
          : `Admin created. Email delivery failed (${json.email_error || 'unknown error'}) — temporary password: ${json.temp_password}`,
        'success'
      );
      loadUsers();
    } catch (err) {
      showNotification('Error: ' + err.message, 'error');
    } finally {
      submitCreateAdmin.disabled = false;
      submitCreateAdmin.textContent = 'Create Admin';
    }
  });

  inviteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = inviteEmail.value;
    const inviteCode = crypto.randomUUID();
    const inviteUrl = `${window.location.origin}/register?email=${encodeURIComponent(email)}&code=${inviteCode}`;
    showNotification('Invite link: ' + inviteUrl, 'success');
    inviteModal.classList.add('hidden');
    inviteForm.reset();
  });

  statusFilter?.addEventListener('change', applyFilters);
  roleFilter?.addEventListener('change', applyFilters);

  inviteModal?.addEventListener('click', (e) => {
    if (e.target === inviteModal) { inviteModal.classList.add('hidden'); inviteForm.reset(); }
  });

  loadUsers();
</script>

</Layout>
