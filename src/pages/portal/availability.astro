---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Availability Requests - Company Portal">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-2xl font-bold text-white mb-6">Availability Requests</h1>
    <p class="text-gray-400 mb-6">Mark items as available or unavailable. Your responses help us process purchase orders quickly.</p>

    <!-- Availability Orders List -->
    <div id="availOrdersList" class="space-y-6">
      <div class="text-center text-gray-400 py-8">Loading availability requests...</div>
    </div>
  </div>
</Layout>

<script>
  async function loadAvailabilityOrders() {
    const resp = await fetch('/api/availability');
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderAvailOrders(data || []);
  }

  function renderAvailOrders(orders: any[]) {
    const container = document.getElementById('availOrdersList');
    if (!container) return;

    if (orders.length === 0) {
      container.innerHTML = '<div class="text-center text-gray-400 py-8">No availability requests at this time.</div>';
      return;
    }

    container.innerHTML = orders.map(ao => `
      <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden" data-ao-id="${ao.id}">
        <div class="p-4 flex justify-between items-center border-b border-gray-700">
          <div>
            <h3 class="text-white font-semibold">Availability Request</h3>
            <p class="text-sm text-gray-400">${ao.total_items} items · Status: 
              <span class="${ao.status === 'responded' ? 'text-green-400' : ao.status === 'partially_responded' ? 'text-yellow-400' : 'text-blue-400'}">
                ${ao.status.replace(/_/g, ' ')}
              </span>
            </p>
          </div>
          <div class="flex gap-3 items-center">
            <span class="text-sm text-gray-400">${ao.available_count || 0} available · ${ao.unavailable_count || 0} unavailable</span>
            <button onclick="window.loadResponses('${ao.id}')" class="px-3 py-1.5 bg-purple-600 text-white text-sm rounded-lg hover:bg-purple-700">
              ${ao.status === 'responded' ? 'View' : 'Respond'}
            </button>
          </div>
        </div>
        <div id="responses-${ao.id}" class="hidden"></div>
      </div>
    `).join('');
  }

  (window as any).loadResponses = async (aoId: string) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;

    // Toggle visibility
    if (!container.classList.contains('hidden') && container.innerHTML) {
      container.classList.add('hidden');
      return;
    }

    container.classList.remove('hidden');
    container.innerHTML = '<div class="p-4 text-gray-400">Loading items...</div>';

    const resp = await fetch(`/api/availability?id=${aoId}`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="p-4">
        <div class="flex justify-between mb-3">
          <div class="flex gap-2">
            <button onclick="window.markAll('${aoId}', true)" class="px-3 py-1 text-xs bg-green-700 text-white rounded hover:bg-green-600">Mark All Available</button>
            <button onclick="window.markAll('${aoId}', false)" class="px-3 py-1 text-xs bg-red-700 text-white rounded hover:bg-red-600">Mark All Unavailable</button>
          </div>
          <button onclick="window.submitResponses('${aoId}')" class="px-4 py-1.5 bg-purple-600 text-white text-sm rounded-lg hover:bg-purple-700">Save Responses</button>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-gray-700/50">
            <tr>
              <th class="px-3 py-2 text-left text-gray-300">Barcode</th>
              <th class="px-3 py-2 text-left text-gray-300">Title</th>
              <th class="px-3 py-2 text-right text-gray-300">Qty</th>
              <th class="px-3 py-2 text-right text-gray-300">Boxes</th>
              <th class="px-3 py-2 text-center text-gray-300">Available</th>
              <th class="px-3 py-2 text-left text-gray-300">Comment</th>
            </tr>
          </thead>
          <tbody>
            ${(data || []).map((r: any) => `
              <tr class="border-b border-gray-700/50" data-resp-id="${r.id}">
                <td class="px-3 py-2 text-white font-mono text-xs">${r.order_item?.barcode || '-'}</td>
                <td class="px-3 py-2 text-white truncate max-w-xs">${r.order_item?.title || '-'}</td>
                <td class="px-3 py-2 text-right text-white">${r.order_item?.order_qty || 0}</td>
                <td class="px-3 py-2 text-right text-white">${Number(r.order_item?.boxes || 0).toFixed(1)}</td>
                <td class="px-3 py-2 text-center">
                  <select class="avail-select px-2 py-1 bg-gray-700 border border-gray-600 rounded text-white text-xs" data-id="${r.id}">
                    <option value="" ${r.is_available === null ? 'selected' : ''}>--</option>
                    <option value="true" ${r.is_available === true ? 'selected' : ''}>Yes</option>
                    <option value="false" ${r.is_available === false ? 'selected' : ''}>No</option>
                  </select>
                </td>
                <td class="px-3 py-2">
                  <input type="text" class="comment-input w-full px-2 py-1 bg-gray-700 border border-gray-600 rounded text-white text-xs" 
                    data-id="${r.id}" value="${r.comment || ''}" placeholder="Optional comment" />
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  };

  (window as any).markAll = (aoId: string, available: boolean) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;
    container.querySelectorAll('.avail-select').forEach((select: any) => {
      select.value = String(available);
    });
  };

  (window as any).submitResponses = async (aoId: string) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;

    const responses: any[] = [];
    container.querySelectorAll('.avail-select').forEach((select: any) => {
      const id = select.dataset.id;
      const value = select.value;
      if (value === '') return;

      const commentInput = container.querySelector(`.comment-input[data-id="${id}"]`) as HTMLInputElement;
      responses.push({
        id,
        is_available: value === 'true',
        comment: commentInput?.value || null,
      });
    });

    if (responses.length === 0) {
      alert('Please mark at least one item before saving.');
      return;
    }

    const resp = await fetch('/api/availability', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'respond', availability_order_id: aoId, responses }),
    });

    if (resp.ok) {
      alert(`Saved ${responses.length} responses.`);
      loadAvailabilityOrders();
    } else {
      alert('Failed to save responses. Please try again.');
    }
  };

  // Auto-expand a specific availability order when focus query param is present.
  async function init() {
    await loadAvailabilityOrders();
    const params = new URLSearchParams(window.location.search);
    const focusId = params.get('focus');
    if (focusId) {
      // Wait one tick for DOM to settle, then trigger expansion.
      setTimeout(() => {
        (window as any).loadResponses(focusId);
        const card = document.querySelector(`[data-ao-id="${focusId}"]`);
        card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
