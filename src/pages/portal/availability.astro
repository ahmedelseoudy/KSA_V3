---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Availability Requests - Company Portal">
  <div class="max-w-7xl mx-auto">
    <PageHeader title="Availability Requests" subtitle="Mark items as available or unavailable — your responses help us process purchase orders quickly" />

    <!-- Availability Orders List -->
    <div id="availOrdersList" class="space-y-4">
      <div class="text-center text-gray-500 text-sm animate-pulse py-12">Loading availability requests...</div>
    </div>
  </div>
</Layout>

<script>
  async function loadAvailabilityOrders() {
    const resp = await fetch('/api/availability');
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderAvailOrders(data || []);
  }

  function renderAvailOrders(orders: any[]) {
    const container = document.getElementById('availOrdersList');
    if (!container) return;

    if (orders.length === 0) {
      container.innerHTML = `
        <div class="py-12 text-center bg-gray-800/40 border border-gray-700/60 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-10 w-10 mx-auto text-gray-600 mb-3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6M9 4.5h6a2.25 2.25 0 0 1 2.25 2.25v.75H6.75v-.75A2.25 2.25 0 0 1 9 4.5Zm-3.75 3h13.5A1.5 1.5 0 0 1 20.25 9v10.5a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5V9a1.5 1.5 0 0 1 1.5-1.5Z" />
          </svg>
          <p class="text-gray-400 text-sm">No availability requests at this time.</p>
        </div>`;
      return;
    }

    container.innerHTML = orders.map(ao => `
      <div class="bg-gray-800/60 rounded-xl border border-gray-700/60 shadow-card overflow-hidden" data-ao-id="${ao.id}">
        <div class="p-5 flex flex-wrap justify-between items-center gap-3 border-b border-gray-700/60">
          <div class="min-w-0">
            <h3 class="text-white font-semibold">Availability Request</h3>
            <p class="text-sm text-gray-400 mt-1">${ao.total_items} items ·
              <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${
                ao.status === 'responded' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
                ao.status === 'partially_responded' ? 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30' :
                'bg-blue-500/10 text-blue-300 ring-1 ring-inset ring-blue-500/30'
              }">
                ${ao.status.replace(/_/g, ' ')}
              </span>
            </p>
          </div>
          <div class="flex gap-3 items-center flex-wrap">
            <span class="text-sm text-gray-400 tabular-nums">${ao.available_count || 0} available · ${ao.unavailable_count || 0} unavailable</span>
            <button onclick="window.loadResponses('${ao.id}')" class="btn btn-primary btn-md">
              ${ao.status === 'responded' ? 'View' : 'Respond'}
            </button>
          </div>
        </div>
        <div id="responses-${ao.id}" class="hidden"></div>
      </div>
    `).join('');
  }

  (window as any).loadResponses = async (aoId: string) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;

    // Toggle visibility
    if (!container.classList.contains('hidden') && container.innerHTML) {
      container.classList.add('hidden');
      return;
    }

    container.classList.remove('hidden');
    container.innerHTML = '<div class="p-5 text-gray-500 text-sm animate-pulse">Loading items...</div>';

    const resp = await fetch(`/api/availability?id=${aoId}`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="p-5">
        <div class="flex flex-wrap justify-between items-center gap-3 mb-4">
          <div class="flex gap-2 flex-wrap">
            <button onclick="window.markAll('${aoId}', true)" class="inline-flex items-center justify-center gap-2 px-2.5 py-1.5 text-xs font-medium text-green-300 bg-green-500/10 hover:bg-green-500/20 border border-green-500/30 rounded-lg transition-colors">Mark All Available</button>
            <button onclick="window.markAll('${aoId}', false)" class="inline-flex items-center justify-center gap-2 px-2.5 py-1.5 text-xs font-medium text-red-300 bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 rounded-lg transition-colors">Mark All Unavailable</button>
          </div>
          <button onclick="window.submitResponses('${aoId}')" class="btn btn-primary btn-md">Save Responses</button>
        </div>
        <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
          <table class="w-full text-sm">
            <thead>
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Barcode</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Title</th>
                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Qty</th>
                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Boxes</th>
                <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Available</th>
                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Comment</th>
              </tr>
            </thead>
            <tbody>
              ${(data || []).map((r: any) => `
                <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors" data-resp-id="${r.id}">
                  <td class="px-4 py-3 text-white font-mono text-xs">${r.order_item?.barcode || '-'}</td>
                  <td class="px-4 py-3 text-white truncate max-w-xs">${r.order_item?.title || '-'}</td>
                  <td class="px-4 py-3 text-right text-white tabular-nums">${r.order_item?.order_qty || 0}</td>
                  <td class="px-4 py-3 text-right text-white tabular-nums">${Number(r.order_item?.boxes || 0).toFixed(1)}</td>
                  <td class="px-4 py-3 text-center">
                    <select class="avail-select px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" data-id="${r.id}">
                      <option value="" ${r.is_available === null ? 'selected' : ''}>--</option>
                      <option value="true" ${r.is_available === true ? 'selected' : ''}>Yes</option>
                      <option value="false" ${r.is_available === false ? 'selected' : ''}>No</option>
                    </select>
                  </td>
                  <td class="px-4 py-3">
                    <input type="text" class="comment-input w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                      data-id="${r.id}" value="${r.comment || ''}" placeholder="Optional comment" />
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      </div>
    `;
  };

  (window as any).markAll = (aoId: string, available: boolean) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;
    container.querySelectorAll('.avail-select').forEach((select: any) => {
      select.value = String(available);
    });
  };

  (window as any).submitResponses = async (aoId: string) => {
    const container = document.getElementById(`responses-${aoId}`);
    if (!container) return;

    const responses: any[] = [];
    container.querySelectorAll('.avail-select').forEach((select: any) => {
      const id = select.dataset.id;
      const value = select.value;
      if (value === '') return;

      const commentInput = container.querySelector(`.comment-input[data-id="${id}"]`) as HTMLInputElement;
      responses.push({
        id,
        is_available: value === 'true',
        comment: commentInput?.value || null,
      });
    });

    if (responses.length === 0) {
      alert('Please mark at least one item before saving.');
      return;
    }

    const resp = await fetch('/api/availability', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'respond', availability_order_id: aoId, responses }),
    });

    if (resp.ok) {
      alert(`Saved ${responses.length} responses.`);
      loadAvailabilityOrders();
    } else {
      alert('Failed to save responses. Please try again.');
    }
  };

  // Auto-expand a specific availability order when focus query param is present.
  async function init() {
    await loadAvailabilityOrders();
    const params = new URLSearchParams(window.location.search);
    const focusId = params.get('focus');
    if (focusId) {
      // Wait one tick for DOM to settle, then trigger expansion.
      setTimeout(() => {
        (window as any).loadResponses(focusId);
        const card = document.querySelector(`[data-ao-id="${focusId}"]`);
        card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
