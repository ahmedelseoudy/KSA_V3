---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Your Deliveries - Company Portal">
  <div id="portalDeliveriesRoot" class="max-w-7xl mx-auto">
    <h1 class="text-2xl font-bold text-white mb-6">Your Deliveries</h1>

    <!-- Filters -->
    <div class="bg-gray-800 rounded-lg p-4 mb-6 flex gap-4 items-end">
      <div>
        <label class="block text-sm text-gray-400 mb-1">Status</label>
        <select id="statusFilter" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white">
          <option value="">All</option>
          <option value="sent">Sent</option>
          <option value="confirmed">Confirmed</option>
          <option value="partially_delivered">Partially Delivered</option>
          <option value="delivered">Delivered</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
        <p class="text-gray-400 text-sm">Total Deliveries</p>
        <p class="text-2xl font-bold text-white" id="totalDeliveries">-</p>
      </div>
      <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
        <p class="text-gray-400 text-sm">Total Value</p>
        <p class="text-2xl font-bold text-green-400" id="totalValue">-</p>
      </div>
      <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
        <p class="text-gray-400 text-sm">Pending Delivery</p>
        <p class="text-2xl font-bold text-yellow-400" id="pendingDelivery">-</p>
      </div>
      <div class="bg-gray-800 rounded-lg p-4 border border-gray-700">
        <p class="text-gray-400 text-sm">Fully Delivered</p>
        <p class="text-2xl font-bold text-blue-400" id="fullyDelivered">-</p>
      </div>
    </div>

    <!-- PO Table -->
    <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-700/50">
            <tr>
              <th class="px-3 py-3 text-left text-gray-300 w-8"></th>
              <th class="px-4 py-3 text-left text-gray-300">PO Number</th>
              <th class="px-4 py-3 text-left text-gray-300">Company</th>
              <th class="px-4 py-3 text-right text-gray-300">Items</th>
              <th class="px-4 py-3 text-right text-gray-300">Total Amount</th>
              <th class="px-4 py-3 text-left text-gray-300">Delivery Date</th>
              <th class="px-4 py-3 text-left text-gray-300">Availability</th>
              <th class="px-4 py-3 text-center text-gray-300">Status</th>
              <th class="px-4 py-3 text-left text-gray-300">Created</th>
              <th class="px-4 py-3 text-center text-gray-300">Actions</th>
            </tr>
          </thead>
          <tbody id="poTableBody">
            <tr><td colspan="10" class="px-4 py-8 text-center text-gray-400">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  const statusColors = {
    draft: 'bg-gray-700 text-gray-300',
    sent: 'bg-blue-900/30 text-blue-300',
    confirmed: 'bg-purple-900/30 text-purple-300',
    partially_delivered: 'bg-yellow-900/30 text-yellow-300',
    delivered: 'bg-green-900/30 text-green-300',
    cancelled: 'bg-red-900/30 text-red-300',
  } as Record<string, string>;

  async function loadPOs() {
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';
    const params = new URLSearchParams();
    if (status) params.set('status', status);

    const resp = await fetch(`/api/purchase-orders?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    const pos = data || [];

    // Stats
    document.getElementById('totalDeliveries')!.textContent = String(pos.length);
    const totalVal = pos.reduce((s: number, po: any) => s + Number(po.total_amount || 0), 0);
    document.getElementById('totalValue')!.textContent = `$${totalVal.toFixed(0)}`;
    document.getElementById('pendingDelivery')!.textContent = String(pos.filter((po: any) => ['sent', 'confirmed', 'partially_delivered'].includes(po.status)).length);
    document.getElementById('fullyDelivered')!.textContent = String(pos.filter((po: any) => po.status === 'delivered').length);

    renderPOs(pos);
  }

  function renderPOs(pos: any[]) {
    const tbody = document.getElementById('poTableBody');
    if (!tbody) return;

    if (pos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="px-4 py-8 text-center text-gray-400">No purchase orders found.</td></tr>';
      return;
    }

    tbody.innerHTML = pos.map(po => {
      const delivery = po.delivery_date ? new Date(po.delivery_date).toLocaleDateString() : '-';
      const availabilityLink = '-';
      return `
      <tr class="border-b border-gray-700/50 group" data-row="${po.id}">
        <td class="px-3 py-3 align-top">
          <button class="po-expand-btn w-6 h-6 flex items-center justify-center rounded bg-gray-700 hover:bg-gray-600 text-white text-xs" aria-expanded="false" aria-controls="po-details-${po.id}" data-id="${po.id}">+</button>
        </td>
        <td class="px-4 py-3 text-white font-mono">${po.po_number || '-'}</td>
        <td class="px-4 py-3 text-white">${po.company?.name || '-'}</td>
        <td class="px-4 py-3 text-right text-white">${po.total_items}</td>
        <td class="px-4 py-3 text-right text-white">$${Number(po.total_amount || 0).toFixed(2)}</td>
        <td class="px-4 py-3 text-white">${delivery}</td>
        <td class="px-4 py-3">${availabilityLink}</td>
        <td class="px-4 py-3 text-center">
          <span class="px-2 py-0.5 text-xs rounded-full ${statusColors[po.status] || 'bg-gray-700 text-gray-300'}">${po.status.replace(/_/g, ' ')}</span>
        </td>
        <td class="px-4 py-3 text-gray-400 text-sm">${new Date(po.created_at).toLocaleDateString()}</td>
        <td class="px-4 py-3 text-center">
          <a href="/portal/comparison?po_id=${po.id}" class="text-sm text-purple-400 hover:text-purple-300">Compare</a>
        </td>
      </tr>
      <tr id="po-details-${po.id}" class="hidden border-b border-gray-800/50 bg-gray-900/40" data-loaded="false">
        <td></td>
        <td class="px-4 py-3" colspan="9">
          <div class="text-gray-400 text-sm" id="po-details-content-${po.id}">Loading items...</div>
        </td>
      </tr>
    `}).join('');

    // Wire expand/collapse and lazy-load items
    const btns = tbody.querySelectorAll('.po-expand-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
        if (!id) return;
        const row = document.getElementById(`po-details-${id}`)!;
        const btnEl = e.currentTarget as HTMLButtonElement;
        const expanded = btnEl.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          btnEl.setAttribute('aria-expanded', 'false');
          btnEl.textContent = '+';
          row.classList.add('hidden');
          return;
        }
        btnEl.setAttribute('aria-expanded', 'true');
        btnEl.textContent = '−';
        row.classList.remove('hidden');
        if (row.getAttribute('data-loaded') !== 'true') {
          await loadPOItems(id);
          row.setAttribute('data-loaded', 'true');
        }
      });
    });
  }

  async function loadPOItems(poId: string) {
    const container = document.getElementById(`po-details-content-${poId}`);
    if (!container) return;
    container.innerHTML = '<div class="text-gray-400">Loading items...</div>';

    const resp = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-700/50">
            <tr>
              <th class="px-3 py-2 text-left text-gray-300">Product</th>
              <th class="px-3 py-2 text-right text-gray-300">Ordered</th>
              <th class="px-3 py-2 text-right text-gray-300">Boxes</th>
              <th class="px-3 py-2 text-right text-gray-300">Price</th>
              <th class="px-3 py-2 text-right text-gray-300">Delivered</th>
              <th class="px-3 py-2 text-center text-gray-300">Status</th>
              <th class="px-3 py-2 text-left text-gray-300">Notes</th>
            </tr>
          </thead>
          <tbody>
            ${(data || []).map((item: any) => `
              <tr class="border-b border-gray-700/50" data-item-id="${item.id}">
                <td class="px-3 py-2 text-white">${item.product?.title || item.product?.barcode || '-'}</td>
                <td class="px-3 py-2 text-right text-white">${item.quantity}</td>
                <td class="px-3 py-2 text-right text-white">${Number(item.boxes).toFixed(1)}</td>
                <td class="px-3 py-2 text-right text-white">$${Number(item.total_price).toFixed(2)}</td>
                <td class="px-3 py-2 text-right">${item.delivered_qty ?? 0}</td>
                <td class="px-3 py-2 text-center">
                  <span class="px-2 py-0.5 text-xs rounded-full ${
                    item.delivery_status === 'delivered' ? 'bg-green-900/30 text-green-300' :
                    item.delivery_status === 'partial' ? 'bg-yellow-900/30 text-yellow-300' :
                    'bg-gray-700 text-gray-400'
                  }">${item.delivery_status}</span>
                </td>
                <td class="px-3 py-2 text-gray-300">${item.delivery_notes ? String(item.delivery_notes) : '-'}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  document.getElementById('statusFilter')?.addEventListener('change', loadPOs);

  async function init() {
    await loadPOs();
    const params = new URLSearchParams(window.location.search);
    const focusPo = params.get('po_id');
    if (focusPo) {
      setTimeout(() => {
        const btn = document.querySelector(`.po-expand-btn[data-id="${focusPo}"]`) as HTMLButtonElement | null;
        if (btn) btn.click();
        document.getElementById(`po-details-${focusPo}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
