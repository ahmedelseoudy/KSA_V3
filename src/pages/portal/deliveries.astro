---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import StatCard from '../../components/ui/StatCard.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Your Deliveries - Company Portal">
  <div id="portalDeliveriesRoot" class="max-w-7xl mx-auto">
    <PageHeader title="Your Deliveries" subtitle="Track delivery progress and item-level status for your purchase orders" />

    <!-- Filters -->
    <div class="flex flex-wrap items-center gap-3 bg-gray-800/60 border border-gray-700/60 rounded-xl p-3 mb-6">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Status</label>
        <select id="statusFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
          <option value="">All</option>
          <option value="sent">Sent</option>
          <option value="confirmed">Confirmed</option>
          <option value="partially_delivered">Partially Delivered</option>
          <option value="delivered">Delivered</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <StatCard label="Total Deliveries" valueId="totalDeliveries" valueClass="text-white" />
      <StatCard label="Total Value" valueId="totalValue" valueClass="text-green-400" />
      <StatCard label="Pending Delivery" valueId="pendingDelivery" valueClass="text-yellow-400" />
      <StatCard label="Fully Delivered" valueId="fullyDelivered" valueClass="text-blue-400" />
    </div>

    <!-- PO Table -->
    <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
      <table class="w-full text-sm">
        <thead>
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80 w-8"></th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">PO Number</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Company</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Items</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Total Amount</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivery Date</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Availability</th>
            <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Created</th>
            <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Actions</th>
          </tr>
        </thead>
        <tbody id="poTableBody">
          <tr><td colspan="10" class="px-4 py-12 text-center text-gray-500 text-sm animate-pulse">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  const statusColors = {
    draft: 'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30',
    sent: 'bg-blue-500/10 text-blue-300 ring-1 ring-inset ring-blue-500/30',
    confirmed: 'bg-purple-500/10 text-purple-300 ring-1 ring-inset ring-purple-500/30',
    partially_delivered: 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30',
    delivered: 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30',
    cancelled: 'bg-red-500/10 text-red-300 ring-1 ring-inset ring-red-500/30',
  } as Record<string, string>;

  async function loadPOs() {
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';
    const params = new URLSearchParams();
    if (status) params.set('status', status);

    const resp = await fetch(`/api/purchase-orders?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    const pos = data || [];

    // Stats
    document.getElementById('totalDeliveries')!.textContent = String(pos.length);
    const totalVal = pos.reduce((s: number, po: any) => s + Number(po.total_amount || 0), 0);
    document.getElementById('totalValue')!.textContent = `$${totalVal.toFixed(0)}`;
    document.getElementById('pendingDelivery')!.textContent = String(pos.filter((po: any) => ['sent', 'confirmed', 'partially_delivered'].includes(po.status)).length);
    document.getElementById('fullyDelivered')!.textContent = String(pos.filter((po: any) => po.status === 'delivered').length);

    renderPOs(pos);
  }

  function renderPOs(pos: any[]) {
    const tbody = document.getElementById('poTableBody');
    if (!tbody) return;

    if (pos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="px-4 py-12 text-center text-gray-400 text-sm">No purchase orders found.</td></tr>';
      return;
    }

    tbody.innerHTML = pos.map(po => {
      const delivery = po.delivery_date ? new Date(po.delivery_date).toLocaleDateString() : '-';
      const availabilityLink = '-';
      return `
      <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors group" data-row="${po.id}">
        <td class="px-4 py-3 align-top">
          <button class="po-expand-btn w-6 h-6 inline-flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-200 text-xs transition-colors" aria-expanded="false" aria-controls="po-details-${po.id}" data-id="${po.id}">+</button>
        </td>
        <td class="px-4 py-3 text-white font-mono">${po.po_number || '-'}</td>
        <td class="px-4 py-3 text-white">${po.company?.name || '-'}</td>
        <td class="px-4 py-3 text-right text-white tabular-nums">${po.total_items}</td>
        <td class="px-4 py-3 text-right text-white tabular-nums">$${Number(po.total_amount || 0).toFixed(2)}</td>
        <td class="px-4 py-3 text-white">${delivery}</td>
        <td class="px-4 py-3 text-gray-400">${availabilityLink}</td>
        <td class="px-4 py-3 text-center">
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${statusColors[po.status] || 'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30'}">${po.status.replace(/_/g, ' ')}</span>
        </td>
        <td class="px-4 py-3 text-gray-400 text-sm">${new Date(po.created_at).toLocaleDateString()}</td>
        <td class="px-4 py-3 text-center">
          <a href="/portal/comparison?po_id=${po.id}" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">Compare</a>
        </td>
      </tr>
      <tr id="po-details-${po.id}" class="hidden border-t border-gray-700/40 bg-gray-900/40" data-loaded="false">
        <td></td>
        <td class="px-4 py-3" colspan="9">
          <div class="text-gray-400 text-sm" id="po-details-content-${po.id}">Loading items...</div>
        </td>
      </tr>
    `}).join('');

    // Wire expand/collapse and lazy-load items
    const btns = tbody.querySelectorAll('.po-expand-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
        if (!id) return;
        const row = document.getElementById(`po-details-${id}`)!;
        const btnEl = e.currentTarget as HTMLButtonElement;
        const expanded = btnEl.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          btnEl.setAttribute('aria-expanded', 'false');
          btnEl.textContent = '+';
          row.classList.add('hidden');
          return;
        }
        btnEl.setAttribute('aria-expanded', 'true');
        btnEl.textContent = '−';
        row.classList.remove('hidden');
        if (row.getAttribute('data-loaded') !== 'true') {
          await loadPOItems(id);
          row.setAttribute('data-loaded', 'true');
        }
      });
    });
  }

  async function loadPOItems(poId: string) {
    const container = document.getElementById(`po-details-content-${poId}`);
    if (!container) return;
    container.innerHTML = '<div class="text-gray-500 text-sm animate-pulse">Loading items...</div>';

    const resp = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Product</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Ordered</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Boxes</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Price</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivered</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Notes</th>
            </tr>
          </thead>
          <tbody>
            ${(data || []).map((item: any) => `
              <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors" data-item-id="${item.id}">
                <td class="px-4 py-3 text-white">${item.product?.title || item.product?.barcode || '-'}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">${item.quantity}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">${Number(item.boxes).toFixed(1)}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">$${Number(item.total_price).toFixed(2)}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">${item.delivered_qty ?? 0}</td>
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${
                    item.delivery_status === 'delivered' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
                    item.delivery_status === 'partial' ? 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30' :
                    'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30'
                  }">${item.delivery_status}</span>
                </td>
                <td class="px-4 py-3 text-gray-300">${item.delivery_notes ? String(item.delivery_notes) : '-'}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  document.getElementById('statusFilter')?.addEventListener('change', loadPOs);

  async function init() {
    await loadPOs();
    const params = new URLSearchParams(window.location.search);
    const focusPo = params.get('po_id');
    if (focusPo) {
      setTimeout(() => {
        const btn = document.querySelector(`.po-expand-btn[data-id="${focusPo}"]`) as HTMLButtonElement | null;
        if (btn) btn.click();
        document.getElementById(`po-details-${focusPo}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
