---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Comparison - Company Portal">
  <div class="max-w-7xl mx-auto">
    <PageHeader title="Comparison" subtitle="Compare requested, available, ordered, and delivered quantities for a purchase order" />

    <div class="flex flex-wrap items-center gap-3 bg-gray-800/60 border border-gray-700/60 rounded-xl p-3 mb-6">
      <form id="compareForm" class="flex flex-wrap items-end gap-3">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Purchase Order</label>
          <input id="poIdInput" type="text" placeholder="Enter PO ID or use link"
                 class="w-80 max-w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
        </div>
        <button type="submit" class="btn btn-primary btn-md">Load</button>
      </form>
    </div>

    <div id="header" class="bg-gray-800/60 rounded-xl p-5 border border-gray-700/60 shadow-card mb-4 hidden"></div>

    <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
      <table class="w-full text-sm">
        <thead>
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Product</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Requested</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Available</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Ordered</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivered</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Availability Notes</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivery Notes</th>
          </tr>
        </thead>
        <tbody id="compareBody">
          <tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 text-sm">Provide a PO via link or input to view comparison.</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  async function loadComparison(poId) {
    const bodyEl = document.getElementById('compareBody');
    const headerEl = document.getElementById('header');
    if (!bodyEl || !headerEl) return;

    if (!poId) {
      bodyEl.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 text-sm">Provide a PO via link or input to view comparison.</td></tr>';
      headerEl.classList.add('hidden');
      return;
    }

    // Header
    try {
      const h = await fetch(`/api/purchase-orders?id=${poId}`);
      if (h.ok) {
        const json = await h.json();
        const po = Array.isArray(json.data) ? json.data[0] : null;
        if (po) {
          const delivery = po.delivery_date ? new Date(po.delivery_date).toLocaleDateString() : '-';
          headerEl.innerHTML = `
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="min-w-0">
                <div class="text-white font-mono font-semibold">PO: ${po.po_number || po.id}</div>
                <div class="text-gray-300 text-sm mt-1">Company: ${po.company?.name || '-'}</div>
                <div class="text-gray-400 text-sm mt-0.5">Status:
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${
                    po.status === 'delivered' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
                    po.status === 'confirmed' ? 'bg-purple-500/10 text-purple-300 ring-1 ring-inset ring-purple-500/30' :
                    po.status === 'partially_delivered' ? 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30' :
                    po.status === 'cancelled' ? 'bg-red-500/10 text-red-300 ring-1 ring-inset ring-red-500/30' :
                    'bg-blue-500/10 text-blue-300 ring-1 ring-inset ring-blue-500/30'
                  }">${po.status.replace(/_/g, ' ')}</span>
                  · Delivery by: ${delivery}
                </div>
              </div>
            </div>
          `;
          headerEl.classList.remove('hidden');
        } else {
          headerEl.classList.add('hidden');
        }
      }
    } catch (_) {}

    // Items
    bodyEl.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-500 text-sm animate-pulse">Loading...</td></tr>';
    try {
      const r = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
      if (!r.ok) { bodyEl.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 text-sm">Failed to load.</td></tr>'; return; }
      const { data } = await r.json();
      const items = Array.isArray(data) ? data : [];
      if (items.length === 0) {
        bodyEl.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 text-sm">No items found.</td></tr>';
        return;
      }
      const rows = items.map((it) => `
        <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors">
          <td class="px-4 py-3 text-gray-100">${it.product?.title || it.product?.barcode || '-'}</td>
          <td class="px-4 py-3 text-right text-gray-200 tabular-nums">${it.order_item?.order_qty ?? '-'}</td>
          <td class="px-4 py-3 text-right text-gray-200 tabular-nums">${it.availability?.available_qty ?? '-'}</td>
          <td class="px-4 py-3 text-right text-gray-200 tabular-nums">${it.quantity}</td>
          <td class="px-4 py-3 text-right text-gray-200 tabular-nums">${it.delivered_qty ?? 0}</td>
          <td class="px-4 py-3 text-gray-300">${it.availability?.comment ? String(it.availability.comment) : '-'}</td>
          <td class="px-4 py-3 text-gray-300">${it.delivery_notes ? String(it.delivery_notes) : '-'}</td>
        </tr>
      `).join('');
      bodyEl.innerHTML = rows;
    } catch (e) {
      bodyEl.innerHTML = '<tr><td colspan="7" class="px-4 py-12 text-center text-gray-400 text-sm">Error loading comparison.</td></tr>';
    }
  }

  document.getElementById('compareForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const poId = (document.getElementById('poIdInput') as HTMLInputElement)?.value?.trim();
    if (poId) loadComparison(poId);
  });

  (function init() {
    const params = new URLSearchParams(window.location.search);
    const poId = params.get('po_id') || '';
    if (poId) {
      (document.getElementById('poIdInput') as HTMLInputElement).value = poId;
    }
    loadComparison(poId);
  })();
</script>
