---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Purchase Orders - Company Portal">
  <div class="max-w-7xl mx-auto">
    <PageHeader title="Your Purchase Orders" subtitle="Review, confirm, and track the purchase orders sent to you" />

    <div id="poList" class="space-y-4">
      <div class="text-center text-gray-500 text-sm animate-pulse py-12">Loading purchase orders...</div>
    </div>
  </div>
</Layout>

<script>
  async function loadPOs() {
    const resp = await fetch('/api/purchase-orders');
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderPOs(data || []);
  }

  function renderPOs(pos: any[]) {
    const container = document.getElementById('poList');
    if (!container) return;

    if (pos.length === 0) {
      container.innerHTML = `
        <div class="py-12 text-center bg-gray-800/40 border border-gray-700/60 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-10 w-10 mx-auto text-gray-600 mb-3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          <p class="text-gray-400 text-sm">No purchase orders yet.</p>
        </div>`;
      return;
    }

    container.innerHTML = pos.map(po => {
      const delivery = po.delivery_date ? new Date(po.delivery_date).toLocaleDateString() : null;
      const batchId = po.availability_order?.batch?.id || po.availability_order?.batch_id || po.batch_id || '';
      const availabilityLink = batchId ? `<a href="/availability?batch_id=${batchId}" class="text-sm text-purple-400 hover:text-purple-300 ml-3">View Availability</a>` : '';
      return `
      <div class="po-card bg-gray-800/60 rounded-xl border border-gray-700/60 shadow-card p-5">
        <div class="flex flex-wrap justify-between items-start gap-3 mb-3">
          <div class="min-w-0">
            <h3 class="text-lg font-semibold text-white">PO: ${po.po_number || 'N/A'}</h3>
            <p class="text-sm text-gray-400 mt-0.5 tabular-nums">${po.total_items} items · $${Number(po.total_amount || 0).toFixed(2)}</p>
            <p class="text-xs text-gray-500 mt-1">Created: ${new Date(po.created_at).toLocaleDateString()}${delivery ? ` · Delivery by: <span class=\"text-gray-300\">${delivery}</span>` : ''}${availabilityLink ? ` ${availabilityLink}` : ''}</p>
          </div>
          <div class="flex items-center gap-3 flex-wrap">
            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${
              po.status === 'delivered' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
              po.status === 'confirmed' ? 'bg-purple-500/10 text-purple-300 ring-1 ring-inset ring-purple-500/30' :
              po.status === 'partially_delivered' ? 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30' :
              'bg-blue-500/10 text-blue-300 ring-1 ring-inset ring-blue-500/30'
            }">${po.status.replace(/_/g, ' ')}</span>
            ${po.status === 'sent' ? `
              <button onclick="window.confirmPO('${po.id}')" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-card">
                Confirm
              </button>
            ` : ''}
          </div>
        </div>
        <div class="flex items-center gap-4 mt-2 pt-3 border-t border-gray-700/40">
          <button onclick="window.toggleItems('${po.id}')" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">View Items ▼</button>
          <a href="/portal/deliveries?po_id=${po.id}" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">Deliveries</a>
          <a href="/portal/comparison?po_id=${po.id}" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">Compare</a>
        </div>
        <div id="items-${po.id}" class="hidden mt-4"></div>
      </div>
    `}).join('');
  }

  (window as any).confirmPO = async (id: string) => {
    if (!confirm('Confirm this purchase order?')) return;
    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'confirm', id }),
    });
    if (resp.ok) {
      alert('Purchase order confirmed.');
      loadPOs();
    } else alert('Failed to confirm.');
  };

  (window as any).toggleItems = async (poId: string) => {
    const container = document.getElementById(`items-${poId}`);
    if (!container) return;

    if (!container.classList.contains('hidden') && container.innerHTML) {
      container.classList.add('hidden');
      return;
    }
    container.classList.remove('hidden');
    container.innerHTML = '<p class="text-gray-500 text-sm animate-pulse">Loading...</p>';

    const resp = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="overflow-x-auto rounded-xl border border-gray-700/60 bg-gray-800/40">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Product</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Qty</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Boxes</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Price/Box</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Total</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivery</th>
            </tr>
          </thead>
          <tbody>
            ${(data || []).map((item: any) => `
              <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors">
                <td class="px-4 py-3 text-white">${item.product?.title || item.product?.barcode || '-'}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">${item.quantity}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">${Number(item.boxes).toFixed(1)}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">$${Number(item.price_per_box).toFixed(2)}</td>
                <td class="px-4 py-3 text-right text-white tabular-nums">$${Number(item.total_price).toFixed(2)}</td>
                <td class="px-4 py-3 text-center">
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full tabular-nums ${
                    item.delivery_status === 'delivered' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
                    item.delivery_status === 'partial' ? 'bg-yellow-500/10 text-yellow-300 ring-1 ring-inset ring-yellow-500/30' :
                    'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30'
                  }">${item.delivered_qty}/${item.quantity}</span>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  };

  async function init() {
    await loadPOs();
    const params = new URLSearchParams(window.location.search);
    const focusId = params.get('focus');
    if (focusId) {
      setTimeout(() => {
        (window as any).toggleItems(focusId);
        const card = document.querySelector(`#items-${focusId}`)?.closest('.po-card');
        card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
