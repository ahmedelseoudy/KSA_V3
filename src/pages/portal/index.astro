---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || profile.role !== 'company') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Company Portal - KSA CRM">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-2xl font-bold text-white mb-6">Welcome to your Portal</h1>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="bg-gray-800 rounded-lg p-5 border border-gray-700">
        <p class="text-gray-400 text-sm">Pending Availability</p>
        <p class="text-3xl font-bold text-blue-400 mt-1" id="pendingAvail">-</p>
        <a href="/portal/availability" class="text-xs text-blue-400 hover:text-blue-300 mt-2 block">View requests →</a>
      </div>
      <div class="bg-gray-800 rounded-lg p-5 border border-gray-700">
        <p class="text-gray-400 text-sm">Active Purchase Orders</p>
        <p class="text-3xl font-bold text-purple-400 mt-1" id="activePOs">-</p>
        <a href="/portal/purchase-orders" class="text-xs text-purple-400 hover:text-purple-300 mt-2 block">View orders →</a>
      </div>
      <div class="bg-gray-800 rounded-lg p-5 border border-gray-700">
        <p class="text-gray-400 text-sm">Total Products</p>
        <p class="text-3xl font-bold text-green-400 mt-1" id="totalProds">-</p>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="bg-gray-800 rounded-lg p-5 border border-gray-700">
      <h2 class="text-lg font-semibold text-white mb-4">Recent Activity</h2>
      <div id="activityList" class="space-y-3">
        <p class="text-gray-400 text-sm">Loading...</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  async function loadPortalData() {
    // Load pending availability orders
    const availResp = await fetch('/api/availability');
    if (availResp.ok) {
      const { data } = await availResp.json();
      const pending = (data || []).filter((a: any) => a.status === 'pending' || a.status === 'partially_responded');
      const el = document.getElementById('pendingAvail');
      if (el) el.textContent = String(pending.length);
    }

    // Load active POs
    const poResp = await fetch('/api/purchase-orders');
    if (poResp.ok) {
      const { data } = await poResp.json();
      const active = (data || []).filter((po: any) => ['sent', 'confirmed', 'partially_delivered'].includes(po.status));
      const el = document.getElementById('activePOs');
      if (el) el.textContent = String(active.length);
    }

    // Load products count
    const prodResp = await fetch('/api/products?limit=1');
    if (prodResp.ok) {
      const { count } = await prodResp.json();
      const el = document.getElementById('totalProds');
      if (el) el.textContent = String(count || 0);
    }

    // Activity list
    const activityEl = document.getElementById('activityList');
    if (activityEl) {
      activityEl.innerHTML = '<p class="text-gray-500 text-sm">No recent activity</p>';
    }
  }

  loadPortalData();
</script>
