---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/ui/PageHeader.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
const isSuper = profile.role === 'super_admin';
---

<Layout title="Companies - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <div id="pageData" data-is-super={isSuper} class="hidden"></div>
    <PageHeader title="Companies" subtitle="Manage supplier companies, contacts, and portal access invites">
      <button slot="actions" id="addCompanyBtn" class="btn btn-primary btn-md">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add Company
      </button>
    </PageHeader>

    <!-- Search -->
    <div class="flex flex-wrap items-center gap-3 bg-gray-800/60 border border-gray-700/60 rounded-xl p-3 mb-6">
      <div class="flex-1 min-w-[14rem]">
        <input type="text" id="searchInput" placeholder="Search companies..."
          class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
      </div>
      <select id="statusFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
        <option value="">All Status</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
        <option value="suspended">Suspended</option>
      </select>
    </div>

    <!-- Companies Grid -->
    <div id="companiesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="col-span-full text-center text-gray-500 text-sm animate-pulse py-12">Loading companies...</div>
    </div>

    <!-- Add/Edit Company Modal -->
    <div id="companyModal" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl shadow-modal p-6 w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
        <h2 class="text-lg font-semibold text-white mb-4" id="modalTitle">Add Company</h2>
        <form id="companyForm" class="space-y-4">
          <input type="hidden" name="id" />
          <div>
            <label class="block text-sm text-gray-400 mb-1">Company Name *</label>
            <input type="text" name="name" required class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Primary Email</label>
            <input type="email" name="email" class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
            <p class="text-xs text-gray-500 mt-1">Login email for the company portal. An invite link will be emailed when you create a new company.</p>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Additional Emails (CC)</label>
            <div id="additionalEmailsContainer" class="flex flex-wrap gap-1 p-2 bg-gray-800/70 border border-gray-700 rounded-lg min-h-[42px]"></div>
            <input type="email" id="additionalEmailInput" placeholder="Type an email and press Enter" class="mt-2 w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Contact Person</label>
            <input type="text" name="contact_person" class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Phone</label>
            <input type="text" name="phone" class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Address</label>
            <textarea name="address" rows="2" class="w-full px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"></textarea>
          </div>
          <div class="flex justify-end gap-3 pt-2">
            <button type="button" id="closeModal" class="btn btn-secondary btn-md">Cancel</button>
            <button type="submit" class="btn btn-primary btn-md">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const IS_SUPER = (document.getElementById('pageData') as HTMLElement)?.dataset.isSuper === 'true';
  async function loadCompanies() {
    const search = (document.getElementById('searchInput') as HTMLInputElement)?.value || '';
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';

    const params = new URLSearchParams();
    if (search) params.set('search', search);
    if (status) params.set('status', status);

    const resp = await fetch(`/api/companies?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderCompanies(data || []);
  }

  function renderCompanies(companies: any[]) {
    const grid = document.getElementById('companiesGrid');
    if (!grid) return;

    if (companies.length === 0) {
      grid.innerHTML = '<div class="col-span-full py-12 text-center"><svg class="w-10 h-10 mx-auto text-gray-600 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg><p class="text-gray-400 text-sm">No companies found</p></div>';
      return;
    }

    grid.innerHTML = companies.map((c: any) => `
      <div class="bg-gray-800/60 rounded-xl p-5 border border-gray-700/60 shadow-card hover:border-purple-500/50 transition-colors">
        <div class="flex justify-between items-start mb-3">
          <h3 class="text-lg font-semibold text-white">${c.name}</h3>
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ${
            c.status === 'active' ? 'bg-green-500/10 text-green-300 ring-1 ring-inset ring-green-500/30' :
            c.status === 'suspended' ? 'bg-red-500/10 text-red-300 ring-1 ring-inset ring-red-500/30' :
            'bg-gray-500/10 text-gray-300 ring-1 ring-inset ring-gray-500/30'
          }">${c.status}</span>
        </div>
        ${c.email ? `<p class="text-sm text-gray-400 mb-1">📧 ${c.email}</p>` : ''}
        ${(c.additional_emails && c.additional_emails.length) ? `<p class="text-xs text-gray-500 mb-1">+ ${c.additional_emails.length} cc</p>` : ''}
        ${c.contact_person ? `<p class="text-sm text-gray-400 mb-1">👤 ${c.contact_person}</p>` : ''}
        ${c.phone ? `<p class="text-sm text-gray-400 mb-1">📞 ${c.phone}</p>` : ''}
        <div class="mt-3">
          ${c.user_id
            ? '<span class="inline-flex items-center gap-1 text-xs font-medium text-green-300">✓ Portal user linked</span>'
            : '<span class="inline-flex items-center gap-1 text-xs font-medium text-yellow-300">⚠ No portal user. Edit to add an email.</span>'}
        </div>
        <div class="flex flex-wrap items-center gap-2 mt-4 pt-3 border-t border-gray-700/60">
          <button onclick="window.editCompany('${c.id}', ${JSON.stringify(c).replace(/"/g, '&quot;')})"
            class="inline-flex items-center justify-center px-2.5 py-1.5 text-xs font-medium rounded-lg text-purple-300 bg-purple-500/10 hover:bg-purple-500/20 border border-purple-500/30 transition-colors">Edit</button>
          ${c.user_id && IS_SUPER ? `<button onclick="window.resendInvite('${c.id}')" class="inline-flex items-center justify-center px-2.5 py-1.5 text-xs font-medium rounded-lg text-blue-300 bg-blue-500/10 hover:bg-blue-500/20 border border-blue-500/30 transition-colors">Resend invite</button>` : ''}
          <button onclick="window.deleteCompany('${c.id}')"
            class="inline-flex items-center justify-center px-2.5 py-1.5 text-xs font-medium rounded-lg text-red-300 bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 transition-colors ml-auto">Delete</button>
        </div>
      </div>
    `).join('');
  }

  // Modal handling
  document.getElementById('addCompanyBtn')?.addEventListener('click', () => {
    (document.getElementById('modalTitle') as HTMLElement).textContent = 'Add Company';
    (document.getElementById('companyForm') as HTMLFormElement).reset();
    (document.querySelector('#companyForm input[name="id"]') as HTMLInputElement).value = '';
    (window as any).__additionalEmails = [];
    refreshChips();
    document.getElementById('companyModal')?.classList.remove('hidden');
  });

  document.getElementById('closeModal')?.addEventListener('click', () => {
    document.getElementById('companyModal')?.classList.add('hidden');
  });

  // Form submit
  document.getElementById('companyForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const id = formData.get('id') as string;

    const body: any = {
      name: formData.get('name'),
      email: formData.get('email') || null,
      additional_emails: (window as any).__additionalEmails || [],
      contact_person: formData.get('contact_person') || null,
      phone: formData.get('phone') || null,
      address: formData.get('address') || null,
    };

    let resp;
    if (id) {
      body.id = id;
      resp = await fetch('/api/companies', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    } else {
      resp = await fetch('/api/companies', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    }

    if (resp.ok) {
      const result = await resp.json().catch(() => ({}));
      document.getElementById('companyModal')?.classList.add('hidden');
      if (result?.invite) {
        if (result.invite.sent) {
          alert('Company created and invite email sent.');
        } else if (result.invite.error) {
          alert(`Company created but invite email could not be sent: ${result.invite.error}`);
        }
      }
      loadCompanies();
    } else {
      const err = await resp.json();
      alert(err.error || 'Failed to save company');
    }
  });

  // Additional emails chip handling.
  function refreshChips() {
    const container = document.getElementById('additionalEmailsContainer');
    if (!container) return;
    const emails: string[] = (window as any).__additionalEmails || [];
    container.innerHTML = emails.map((e, i) => `
      <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-full bg-purple-500/10 text-purple-300 ring-1 ring-inset ring-purple-500/30">
        ${e}
        <button type="button" onclick="window.__removeChip(${i})" class="hover:text-red-300 transition-colors">×</button>
      </span>
    `).join('') || '<span class="text-xs text-gray-500">No additional recipients</span>';
  }
  (window as any).__removeChip = (i: number) => {
    const arr: string[] = (window as any).__additionalEmails || [];
    arr.splice(i, 1);
    (window as any).__additionalEmails = arr;
    refreshChips();
  };
  document.getElementById('additionalEmailInput')?.addEventListener('keydown', (ev) => {
    const e = ev as KeyboardEvent;
    if (e.key !== 'Enter' && e.key !== ',') return;
    e.preventDefault();
    const input = e.target as HTMLInputElement;
    const val = input.value.trim().toLowerCase();
    if (!val) return;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
      alert('Invalid email');
      return;
    }
    const arr: string[] = (window as any).__additionalEmails || [];
    if (arr.includes(val)) return;
    arr.push(val);
    (window as any).__additionalEmails = arr;
    input.value = '';
    refreshChips();
  });

  (window as any).resendInvite = async (id: string) => {
    if (!confirm('Send a fresh setup link to this company?')) return;
    const resp = await fetch('/api/companies/resend-invite', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ company_id: id }),
    });
    const json = await resp.json().catch(() => ({}));
    if (json.sent) alert('Invite re-sent.');
    else alert(`Failed: ${json.error || 'Unknown error'}`);
  };

  // Edit & delete
  (window as any).editCompany = (id: string, company: any) => {
    (document.getElementById('modalTitle') as HTMLElement).textContent = 'Edit Company';
    const form = document.getElementById('companyForm') as HTMLFormElement;
    (form.querySelector('input[name="id"]') as HTMLInputElement).value = id;
    (form.querySelector('input[name="name"]') as HTMLInputElement).value = company.name || '';
    (form.querySelector('input[name="email"]') as HTMLInputElement).value = company.email || '';
    (form.querySelector('input[name="contact_person"]') as HTMLInputElement).value = company.contact_person || '';
    (form.querySelector('input[name="phone"]') as HTMLInputElement).value = company.phone || '';
    (form.querySelector('textarea[name="address"]') as HTMLTextAreaElement).value = company.address || '';
    (window as any).__additionalEmails = Array.isArray(company.additional_emails) ? [...company.additional_emails] : [];
    refreshChips();
    document.getElementById('companyModal')?.classList.remove('hidden');
  };

  (window as any).deleteCompany = async (id: string) => {
    if (!confirm('Delete this company? This will affect related products and orders.')) return;
    const resp = await fetch(`/api/companies?id=${id}`, { method: 'DELETE' });
    if (resp.ok) loadCompanies();
    else alert('Failed to delete company');
  };

  // Search
  document.getElementById('searchInput')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') loadCompanies(); });
  document.getElementById('statusFilter')?.addEventListener('change', loadCompanies);

  // Init
  loadCompanies();
</script>
