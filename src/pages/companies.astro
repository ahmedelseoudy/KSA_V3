---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Companies - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-white">Companies</h1>
      <button id="addCompanyBtn" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
        + Add Company
      </button>
    </div>

    <!-- Search -->
    <div class="bg-gray-800 rounded-lg p-4 mb-6">
      <div class="flex gap-4 items-end">
        <div class="flex-1">
          <input type="text" id="searchInput" placeholder="Search companies..."
            class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:border-purple-500 focus:outline-none" />
        </div>
        <select id="statusFilter" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none">
          <option value="">All Status</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
          <option value="suspended">Suspended</option>
        </select>
      </div>
    </div>

    <!-- Companies Grid -->
    <div id="companiesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="col-span-full text-center text-gray-400 py-8">Loading companies...</div>
    </div>

    <!-- Add/Edit Company Modal -->
    <div id="companyModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
      <div class="bg-gray-800 rounded-xl p-6 w-full max-w-lg mx-4">
        <h2 class="text-xl font-bold text-white mb-4" id="modalTitle">Add Company</h2>
        <form id="companyForm" class="space-y-4">
          <input type="hidden" name="id" />
          <div>
            <label class="block text-sm text-gray-400 mb-1">Company Name *</label>
            <input type="text" name="name" required class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Primary Email</label>
            <input type="email" name="email" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
            <p class="text-xs text-gray-500 mt-1">Login email for the company portal. An invite link will be emailed when you create a new company.</p>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Additional Emails (CC)</label>
            <div id="additionalEmailsContainer" class="flex flex-wrap gap-1 p-2 bg-gray-700 border border-gray-600 rounded-lg min-h-[42px]"></div>
            <input type="email" id="additionalEmailInput" placeholder="Type an email and press Enter" class="mt-2 w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Contact Person</label>
            <input type="text" name="contact_person" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Phone</label>
            <input type="text" name="phone" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Address</label>
            <textarea name="address" rows="2" class="w-full px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white focus:border-purple-500 focus:outline-none"></textarea>
          </div>
          <div class="flex justify-end gap-3 pt-2">
            <button type="button" id="closeModal" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-500">Cancel</button>
            <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  async function loadCompanies() {
    const search = (document.getElementById('searchInput') as HTMLInputElement)?.value || '';
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';

    const params = new URLSearchParams();
    if (search) params.set('search', search);
    if (status) params.set('status', status);

    const resp = await fetch(`/api/companies?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderCompanies(data || []);
  }

  function renderCompanies(companies: any[]) {
    const grid = document.getElementById('companiesGrid');
    if (!grid) return;

    if (companies.length === 0) {
      grid.innerHTML = '<div class="col-span-full text-center text-gray-400 py-8">No companies found</div>';
      return;
    }

    grid.innerHTML = companies.map((c: any) => `
      <div class="bg-gray-800 rounded-lg p-5 border border-gray-700 hover:border-purple-500/50 transition-colors">
        <div class="flex justify-between items-start mb-3">
          <h3 class="text-lg font-semibold text-white">${c.name}</h3>
          <span class="px-2 py-0.5 text-xs rounded-full ${
            c.status === 'active' ? 'bg-green-900/30 text-green-300' :
            c.status === 'suspended' ? 'bg-red-900/30 text-red-300' :
            'bg-gray-700 text-gray-400'
          }">${c.status}</span>
        </div>
        ${c.email ? `<p class="text-sm text-gray-400 mb-1">📧 ${c.email}</p>` : ''}
        ${(c.additional_emails && c.additional_emails.length) ? `<p class="text-xs text-gray-500 mb-1">+ ${c.additional_emails.length} cc</p>` : ''}
        ${c.contact_person ? `<p class="text-sm text-gray-400 mb-1">👤 ${c.contact_person}</p>` : ''}
        ${c.phone ? `<p class="text-sm text-gray-400 mb-1">📞 ${c.phone}</p>` : ''}
        <div class="mt-3">
          ${c.user_id
            ? '<span class="text-xs text-green-400">✓ Portal user linked</span>'
            : '<span class="text-xs text-yellow-400">⚠ No portal user. Edit to add an email.</span>'}
        </div>
        <div class="flex gap-3 mt-4 pt-3 border-t border-gray-700">
          <button onclick="window.editCompany('${c.id}', ${JSON.stringify(c).replace(/"/g, '&quot;')})" 
            class="text-sm text-purple-400 hover:text-purple-300">Edit</button>
          ${c.user_id ? `<button onclick="window.resendInvite('${c.id}')" class="text-sm text-blue-400 hover:text-blue-300">Resend invite</button>` : ''}
          <button onclick="window.deleteCompany('${c.id}')" 
            class="text-sm text-red-400 hover:text-red-300">Delete</button>
        </div>
      </div>
    `).join('');
  }

  // Modal handling
  document.getElementById('addCompanyBtn')?.addEventListener('click', () => {
    (document.getElementById('modalTitle') as HTMLElement).textContent = 'Add Company';
    (document.getElementById('companyForm') as HTMLFormElement).reset();
    (document.querySelector('#companyForm input[name="id"]') as HTMLInputElement).value = '';
    (window as any).__additionalEmails = [];
    refreshChips();
    document.getElementById('companyModal')?.classList.remove('hidden');
  });

  document.getElementById('closeModal')?.addEventListener('click', () => {
    document.getElementById('companyModal')?.classList.add('hidden');
  });

  // Form submit
  document.getElementById('companyForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const id = formData.get('id') as string;

    const body: any = {
      name: formData.get('name'),
      email: formData.get('email') || null,
      additional_emails: (window as any).__additionalEmails || [],
      contact_person: formData.get('contact_person') || null,
      phone: formData.get('phone') || null,
      address: formData.get('address') || null,
    };

    let resp;
    if (id) {
      body.id = id;
      resp = await fetch('/api/companies', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    } else {
      resp = await fetch('/api/companies', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    }

    if (resp.ok) {
      const result = await resp.json().catch(() => ({}));
      document.getElementById('companyModal')?.classList.add('hidden');
      if (result?.invite) {
        if (result.invite.sent) {
          alert('Company created and invite email sent.');
        } else if (result.invite.error) {
          alert(`Company created but invite email could not be sent: ${result.invite.error}`);
        }
      }
      loadCompanies();
    } else {
      const err = await resp.json();
      alert(err.error || 'Failed to save company');
    }
  });

  // Additional emails chip handling.
  function refreshChips() {
    const container = document.getElementById('additionalEmailsContainer');
    if (!container) return;
    const emails: string[] = (window as any).__additionalEmails || [];
    container.innerHTML = emails.map((e, i) => `
      <span class="inline-flex items-center gap-1 px-2 py-1 text-xs rounded-full bg-purple-900/40 text-purple-200">
        ${e}
        <button type="button" onclick="window.__removeChip(${i})" class="hover:text-red-300">×</button>
      </span>
    `).join('') || '<span class="text-xs text-gray-500">No additional recipients</span>';
  }
  (window as any).__removeChip = (i: number) => {
    const arr: string[] = (window as any).__additionalEmails || [];
    arr.splice(i, 1);
    (window as any).__additionalEmails = arr;
    refreshChips();
  };
  document.getElementById('additionalEmailInput')?.addEventListener('keydown', (ev) => {
    const e = ev as KeyboardEvent;
    if (e.key !== 'Enter' && e.key !== ',') return;
    e.preventDefault();
    const input = e.target as HTMLInputElement;
    const val = input.value.trim().toLowerCase();
    if (!val) return;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
      alert('Invalid email');
      return;
    }
    const arr: string[] = (window as any).__additionalEmails || [];
    if (arr.includes(val)) return;
    arr.push(val);
    (window as any).__additionalEmails = arr;
    input.value = '';
    refreshChips();
  });

  (window as any).resendInvite = async (id: string) => {
    if (!confirm('Send a fresh setup link to this company?')) return;
    const resp = await fetch('/api/companies/resend-invite', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ company_id: id }),
    });
    const json = await resp.json().catch(() => ({}));
    if (json.sent) alert('Invite re-sent.');
    else alert(`Failed: ${json.error || 'Unknown error'}`);
  };

  // Edit & delete
  (window as any).editCompany = (id: string, company: any) => {
    (document.getElementById('modalTitle') as HTMLElement).textContent = 'Edit Company';
    const form = document.getElementById('companyForm') as HTMLFormElement;
    (form.querySelector('input[name="id"]') as HTMLInputElement).value = id;
    (form.querySelector('input[name="name"]') as HTMLInputElement).value = company.name || '';
    (form.querySelector('input[name="email"]') as HTMLInputElement).value = company.email || '';
    (form.querySelector('input[name="contact_person"]') as HTMLInputElement).value = company.contact_person || '';
    (form.querySelector('input[name="phone"]') as HTMLInputElement).value = company.phone || '';
    (form.querySelector('textarea[name="address"]') as HTMLTextAreaElement).value = company.address || '';
    (window as any).__additionalEmails = Array.isArray(company.additional_emails) ? [...company.additional_emails] : [];
    refreshChips();
    document.getElementById('companyModal')?.classList.remove('hidden');
  };

  (window as any).deleteCompany = async (id: string) => {
    if (!confirm('Delete this company? This will affect related products and orders.')) return;
    const resp = await fetch(`/api/companies?id=${id}`, { method: 'DELETE' });
    if (resp.ok) loadCompanies();
    else alert('Failed to delete company');
  };

  // Search
  document.getElementById('searchInput')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') loadCompanies(); });
  document.getElementById('statusFilter')?.addEventListener('change', loadCompanies);

  // Init
  loadCompanies();
</script>
