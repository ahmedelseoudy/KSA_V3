---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import StatCard from '../components/ui/StatCard.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin', 'company'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Delivery Tracking - KSA CRM">
  <div id="deliveriesRoot" class="max-w-7xl mx-auto" data-is-company={profile.role === 'company' ? '1' : '0'}>
    <PageHeader title="Delivery Tracking" subtitle="Record and monitor deliveries against purchase orders" />

    <!-- Filters -->
    <div class="flex flex-wrap items-end gap-3 bg-gray-800/60 border border-gray-700/60 rounded-xl p-3 mb-6">
      <div id="companyFilterGroup">
        <label class="block text-xs text-gray-500 mb-1">Company</label>
        <select id="companyFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent min-w-[12rem]">
          <option value="">All Companies</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Status</label>
        <select id="statusFilter" class="px-3 py-2 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent">
          <option value="">All</option>
          <option value="sent">Sent</option>
          <option value="confirmed">Confirmed</option>
          <option value="partially_delivered">Partially Delivered</option>
          <option value="delivered">Delivered</option>
        </select>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <StatCard label="Total Deliveries" valueId="totalDeliveries" />
      <StatCard label="Total Value" valueId="totalValue" valueClass="text-green-400" />
      <StatCard label="Pending Delivery" valueId="pendingDelivery" valueClass="text-yellow-400" />
      <StatCard label="Fully Delivered" valueId="fullyDelivered" valueClass="text-blue-400" />
    </div>

    <!-- PO Table -->
    <div class="bg-gray-800/40 rounded-xl border border-gray-700/60 shadow-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="px-3 py-3 text-left bg-gray-800/80 w-8"></th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">PO Number</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Company</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Items</th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Total Amount</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivery Date</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Availability</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Created</th>
              <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Actions</th>
            </tr>
          </thead>
          <tbody id="poTableBody">
            <tr><td colspan="10" class="px-4 py-8 text-center text-gray-500 text-sm animate-pulse">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<script>
  const ROOT = document.getElementById('deliveriesRoot') as HTMLElement | null;
  const IS_COMPANY = (ROOT?.getAttribute('data-is-company') || '0') === '1';
  const statusColors = {
    draft: 'bg-gray-500/10 text-gray-300 ring-gray-500/30',
    sent: 'bg-blue-500/10 text-blue-300 ring-blue-500/30',
    confirmed: 'bg-purple-500/10 text-purple-300 ring-purple-500/30',
    partially_delivered: 'bg-yellow-500/10 text-yellow-300 ring-yellow-500/30',
    delivered: 'bg-green-500/10 text-green-300 ring-green-500/30',
    cancelled: 'bg-red-500/10 text-red-300 ring-red-500/30',
  } as Record<string, string>;

  async function loadCompanies() {
    const resp = await fetch('/api/companies');
    if (!resp.ok) return;
    const { data } = await resp.json();
    const select = document.getElementById('companyFilter') as HTMLSelectElement;
    select.innerHTML = `<option value="">All Companies</option>${(data || []).map((c: any) => `<option value="${c.id}">${c.name}</option>`).join('')}`;
  }

  async function loadPurchaseOrders() {
    const company = (document.getElementById('companyFilter') as HTMLSelectElement)?.value || '';
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';
    const params = new URLSearchParams();
    if (company) params.set('company_id', company);
    if (status) params.set('status', status);

    const resp = await fetch(`/api/purchase-orders?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    const pos = data || [];

    // Stats
    document.getElementById('totalDeliveries')!.textContent = String(pos.length);
    const totalVal = pos.reduce((s: number, po: any) => s + Number(po.total_amount || 0), 0);
    document.getElementById('totalValue')!.textContent = `$${totalVal.toFixed(0)}`;
    document.getElementById('pendingDelivery')!.textContent = String(pos.filter((po: any) => ['sent', 'confirmed', 'partially_delivered'].includes(po.status)).length);
    document.getElementById('fullyDelivered')!.textContent = String(pos.filter((po: any) => po.status === 'delivered').length);

    renderPOs(pos);
  }

  function renderPOs(pos: any[]) {
    const tbody = document.getElementById('poTableBody');
    if (!tbody) return;

    if (pos.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="py-12 text-center text-gray-400 text-sm">No purchase orders found.</td></tr>';
      return;
    }

    tbody.innerHTML = pos.map(po => {
      const delivery = po.delivery_date ? new Date(po.delivery_date).toLocaleDateString() : '-';
      const batchId = po.availability_order?.batch?.id || po.availability_order?.batch_id || po.batch_id || '';
      const availabilityLink = batchId ? `<a href="/availability?batch_id=${batchId}" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">View</a>` : '-';
      return `
      <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors group" data-row="${po.id}">
        <td class="px-3 py-3 align-top">
          <button class="po-expand-btn w-6 h-6 inline-flex items-center justify-center rounded-md bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 hover:text-white text-xs transition-colors" aria-expanded="false" aria-controls="po-details-${po.id}" data-id="${po.id}">+</button>
        </td>
        <td class="px-4 py-3 text-white font-mono">${po.po_number || '-'}</td>
        <td class="px-4 py-3 text-white">${po.company?.name || '-'}</td>
        <td class="px-4 py-3 text-right text-white tabular-nums">${po.total_items}</td>
        <td class="px-4 py-3 text-right text-white tabular-nums">$${Number(po.total_amount || 0).toFixed(2)}</td>
        <td class="px-4 py-3 text-white">${delivery}</td>
        <td class="px-4 py-3">${availabilityLink}</td>
        <td class="px-4 py-3 text-center">
          <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ring-1 ring-inset ${statusColors[po.status] || 'bg-gray-500/10 text-gray-300 ring-gray-500/30'}">${po.status.replace(/_/g, ' ')}</span>
        </td>
        <td class="px-4 py-3 text-gray-400 text-sm">${new Date(po.created_at).toLocaleDateString()}</td>
        <td class="px-4 py-3 text-center">
          <a href="/comparison?po_id=${po.id}" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors">Compare</a>
        </td>
      </tr>
      <tr id="po-details-${po.id}" class="hidden border-t border-gray-700/40 bg-gray-900/40" data-loaded="false">
        <td></td>
        <td class="px-4 py-4" colspan="9">
          <div class="text-gray-400 text-sm" id="po-details-content-${po.id}"><span class="text-gray-500 text-sm animate-pulse">Loading items...</span></div>
        </td>
      </tr>
    `}).join('');

    // Wire expand/collapse and lazy-load items
    const btns = tbody.querySelectorAll('.po-expand-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
        if (!id) return;
        const row = document.getElementById(`po-details-${id}`)!;
        const btnEl = e.currentTarget as HTMLButtonElement;
        const expanded = btnEl.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          btnEl.setAttribute('aria-expanded', 'false');
          btnEl.textContent = '+';
          row.classList.add('hidden');
          return;
        }
        btnEl.setAttribute('aria-expanded', 'true');
        btnEl.textContent = '−';
        row.classList.remove('hidden');
        if (row.getAttribute('data-loaded') !== 'true') {
          await loadPOItems(id);
          row.setAttribute('data-loaded', 'true');
        }
      });
    });
  }

  async function loadPOItems(poId: string) {
    const container = document.getElementById(`po-details-content-${poId}`);
    if (!container) return;
    container.innerHTML = '<div class="text-gray-500 text-sm animate-pulse">Loading items...</div>';

    const resp = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    const canEdit = !IS_COMPANY;
    container.innerHTML = `
      <div>
        <div class="overflow-x-auto rounded-lg border border-gray-700/40 bg-gray-800/40">
          <table class="w-full text-sm">
            <thead>
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Product</th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Ordered</th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Boxes</th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Price</th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Delivered</th>
                <th class="px-3 py-2 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Status</th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Notes</th>
                ${canEdit ? '<th class="px-3 py-2 text-center text-xs font-semibold uppercase tracking-wider text-gray-400 bg-gray-800/80">Action</th>' : ''}
              </tr>
            </thead>
            <tbody>
              ${(data || []).map((item: any) => `
                <tr class="border-t border-gray-700/40 hover:bg-gray-800/40 transition-colors" data-item-id="${item.id}">
                  <td class="px-3 py-2 text-white">${item.product?.title || item.product?.barcode || '-'}</td>
                  <td class="px-3 py-2 text-right text-white tabular-nums">${item.quantity}</td>
                  <td class="px-3 py-2 text-right text-white tabular-nums">${Number(item.boxes).toFixed(1)}</td>
                  <td class="px-3 py-2 text-right text-white tabular-nums">$${Number(item.total_price).toFixed(2)}</td>
                  <td class="px-3 py-2 text-right">
                    <input type="number" class="delivered-input w-20 px-2.5 py-1.5 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-xs text-right tabular-nums placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent disabled:opacity-50 disabled:cursor-not-allowed" ${canEdit ? '' : 'disabled'}
                      data-item-id="${item.id}" value="${(item.delivery_status === 'pending' ? item.quantity : (item.delivered_qty ?? 0))}" min="0" max="${item.quantity}" />
                  </td>
                  <td class="px-3 py-2 text-center">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full ring-1 ring-inset ${
                      item.delivery_status === 'delivered' ? 'bg-green-500/10 text-green-300 ring-green-500/30' :
                      item.delivery_status === 'partial' ? 'bg-yellow-500/10 text-yellow-300 ring-yellow-500/30' :
                      'bg-gray-500/10 text-gray-300 ring-gray-500/30'
                    }">${item.delivery_status}</span>
                  </td>
                  <td class="px-3 py-2">
                    <input type="text" class="notes-input w-full px-2.5 py-1.5 bg-gray-800/70 border border-gray-700 rounded-lg text-white text-xs placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent disabled:opacity-50 disabled:cursor-not-allowed" ${canEdit ? '' : 'disabled'}
                      data-item-id="${item.id}" value="${item.delivery_notes || ''}" placeholder="Notes..." />
                  </td>
                  ${canEdit ? `<td class=\"px-3 py-2 text-center\"><button onclick=\"window.saveDelivery('${item.id}', '${poId}')\" class=\"inline-flex items-center justify-center px-2.5 py-1.5 text-xs font-medium text-purple-300 bg-purple-500/10 hover:bg-purple-500/20 border border-purple-500/30 rounded-lg transition-colors\">Save</button></td>` : ''}
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
        ${canEdit ? `<div class=\"mt-3 flex justify-end\"><button onclick=\"window.saveAllDeliveries('${poId}')\" class=\"inline-flex items-center justify-center gap-2 px-4 py-2 bg-purple-600 hover:bg-purple-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-card\">Save All Changes</button></div>` : ''}
      </div>
    `;
  }

  (window as any).saveDelivery = async (itemId: string, poId: string) => {
    const container = document.getElementById(`po-details-content-${poId}`);
    if (!container) return;

    const deliveredInput = container.querySelector(`.delivered-input[data-item-id="${itemId}"]`) as HTMLInputElement;
    const notesInput = container.querySelector(`.notes-input[data-item-id="${itemId}"]`) as HTMLInputElement;

    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'update_delivery',
        items: [{ id: itemId, delivered_qty: parseInt(deliveredInput.value) || 0, delivery_notes: notesInput.value }],
      }),
    });

    if (resp.ok) {
      const json = await resp.json().catch(() => ({}));
      alert(`Saved. Emails dispatched: ${json.emails_dispatched ?? 0}`);
      loadPurchaseOrders();
    } else alert('Failed to save delivery');
  };

  (window as any).saveAllDeliveries = async (poId: string) => {
    const container = document.getElementById(`po-details-content-${poId}`);
    if (!container) return;

    const items: any[] = [];
    container.querySelectorAll('.delivered-input').forEach((input: any) => {
      const itemId = input.dataset.itemId;
      const notesInput = container.querySelector(`.notes-input[data-item-id="${itemId}"]`) as HTMLInputElement;
      items.push({ id: itemId, delivered_qty: parseInt(input.value) || 0, delivery_notes: notesInput?.value || '' });
    });

    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'update_delivery', items }),
    });

    if (resp.ok) {
      const json = await resp.json().catch(() => ({}));
      alert(`Deliveries saved successfully. Emails dispatched: ${json.emails_dispatched ?? 0}`);
      loadPurchaseOrders();
    } else alert('Failed to save deliveries');
  };

  document.getElementById('companyFilter')?.addEventListener('change', loadPurchaseOrders);
  document.getElementById('statusFilter')?.addEventListener('change', loadPurchaseOrders);

  async function init() {
    if ((ROOT?.getAttribute('data-is-company') || '0') === '1') {
      document.getElementById('companyFilterGroup')?.classList.add('hidden');
    } else {
      await loadCompanies();
    }
    await loadPurchaseOrders();
    const params = new URLSearchParams(window.location.search);
    const focusPo = params.get('po_id');
    if (focusPo) {
      setTimeout(() => {
        const btn = document.querySelector(`.po-expand-btn[data-id="${focusPo}"]`) as HTMLButtonElement | null;
        if (btn) btn.click();
        document.getElementById(`po-details-${focusPo}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }
  init();
</script>
