---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
const profile = (user as any)?.profile;

if (!profile || !['admin', 'super_admin'].includes(profile.role)) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Delivery Tracking - KSA CRM">
  <div class="max-w-7xl mx-auto">
    <h1 class="text-2xl font-bold text-white mb-6">Delivery Tracking</h1>

    <!-- Filters -->
    <div class="bg-gray-800 rounded-lg p-4 mb-6 flex gap-4 items-end">
      <div>
        <label class="block text-sm text-gray-400 mb-1">Company</label>
        <select id="companyFilter" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white">
          <option value="">All Companies</option>
        </select>
      </div>
      <div>
        <label class="block text-sm text-gray-400 mb-1">Status</label>
        <select id="statusFilter" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded-lg text-white">
          <option value="">All</option>
          <option value="sent">Sent</option>
          <option value="confirmed">Confirmed</option>
          <option value="partially_delivered">Partially Delivered</option>
          <option value="delivered">Delivered</option>
        </select>
      </div>
    </div>

    <!-- PO List -->
    <div id="poList" class="space-y-4">
      <div class="text-center text-gray-400 py-8">Loading purchase orders...</div>
    </div>
  </div>
</Layout>

<script>
  async function loadCompanies() {
    const resp = await fetch('/api/companies');
    if (!resp.ok) return;
    const { data } = await resp.json();
    const select = document.getElementById('companyFilter') as HTMLSelectElement;
    select.innerHTML = `<option value="">All Companies</option>${(data || []).map((c: any) => `<option value="${c.id}">${c.name}</option>`).join('')}`;
  }

  async function loadPurchaseOrders() {
    const company = (document.getElementById('companyFilter') as HTMLSelectElement)?.value || '';
    const status = (document.getElementById('statusFilter') as HTMLSelectElement)?.value || '';
    const params = new URLSearchParams();
    if (company) params.set('company_id', company);
    if (status) params.set('status', status);

    const resp = await fetch(`/api/purchase-orders?${params}`);
    if (!resp.ok) return;
    const { data } = await resp.json();
    renderPOs(data || []);
  }

  function renderPOs(pos: any[]) {
    const container = document.getElementById('poList');
    if (!container) return;

    if (pos.length === 0) {
      container.innerHTML = '<div class="text-center text-gray-400 py-8">No purchase orders found.</div>';
      return;
    }

    container.innerHTML = pos.map(po => `
      <div class="bg-gray-800 rounded-lg border border-gray-700 overflow-hidden">
        <div class="p-4 flex justify-between items-center cursor-pointer" onclick="window.togglePOItems('${po.id}')">
          <div>
            <h3 class="text-white font-semibold">${po.company?.name || 'Unknown'} - ${po.po_number || 'No PO#'}</h3>
            <p class="text-sm text-gray-400">${po.total_items} items · $${Number(po.total_amount || 0).toFixed(2)}</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 text-xs rounded-full ${
              po.status === 'delivered' ? 'bg-green-900/30 text-green-300' :
              po.status === 'partially_delivered' ? 'bg-yellow-900/30 text-yellow-300' :
              'bg-blue-900/30 text-blue-300'
            }">${po.status.replace(/_/g, ' ')}</span>
            <span class="text-gray-400 text-sm">▼</span>
          </div>
        </div>
        <div id="po-items-${po.id}" class="hidden border-t border-gray-700"></div>
      </div>
    `).join('');
  }

  (window as any).togglePOItems = async (poId: string) => {
    const container = document.getElementById(`po-items-${poId}`);
    if (!container) return;

    if (!container.classList.contains('hidden') && container.innerHTML) {
      container.classList.add('hidden');
      return;
    }

    container.classList.remove('hidden');
    container.innerHTML = '<div class="p-4 text-gray-400">Loading items...</div>';

    const resp = await fetch(`/api/purchase-orders?id=${poId}&items=true`);
    if (!resp.ok) return;
    const { data } = await resp.json();

    container.innerHTML = `
      <div class="p-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-700/50">
            <tr>
              <th class="px-3 py-2 text-left text-gray-300">Product</th>
              <th class="px-3 py-2 text-right text-gray-300">Ordered</th>
              <th class="px-3 py-2 text-right text-gray-300">Boxes</th>
              <th class="px-3 py-2 text-right text-gray-300">Price</th>
              <th class="px-3 py-2 text-right text-gray-300">Delivered</th>
              <th class="px-3 py-2 text-center text-gray-300">Status</th>
              <th class="px-3 py-2 text-left text-gray-300">Notes</th>
              <th class="px-3 py-2 text-center text-gray-300">Action</th>
            </tr>
          </thead>
          <tbody>
            ${(data || []).map((item: any) => `
              <tr class="border-b border-gray-700/50" data-item-id="${item.id}">
                <td class="px-3 py-2 text-white">${item.product?.title || item.product?.barcode || '-'}</td>
                <td class="px-3 py-2 text-right text-white">${item.quantity}</td>
                <td class="px-3 py-2 text-right text-white">${Number(item.boxes).toFixed(1)}</td>
                <td class="px-3 py-2 text-right text-white">$${Number(item.total_price).toFixed(2)}</td>
                <td class="px-3 py-2 text-right">
                  <input type="number" class="delivered-input w-20 px-2 py-1 bg-gray-700 border border-gray-600 rounded text-white text-xs text-right"
                    data-item-id="${item.id}" value="${item.delivered_qty}" min="0" max="${item.quantity}" />
                </td>
                <td class="px-3 py-2 text-center">
                  <span class="px-2 py-0.5 text-xs rounded-full ${
                    item.delivery_status === 'delivered' ? 'bg-green-900/30 text-green-300' :
                    item.delivery_status === 'partial' ? 'bg-yellow-900/30 text-yellow-300' :
                    'bg-gray-700 text-gray-400'
                  }">${item.delivery_status}</span>
                </td>
                <td class="px-3 py-2">
                  <input type="text" class="notes-input w-full px-2 py-1 bg-gray-700 border border-gray-600 rounded text-white text-xs"
                    data-item-id="${item.id}" value="${item.delivery_notes || ''}" placeholder="Notes..." />
                </td>
                <td class="px-3 py-2 text-center">
                  <button onclick="window.saveDelivery('${item.id}', '${poId}')" class="text-xs text-purple-400 hover:text-purple-300">Save</button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
        <div class="mt-3 flex justify-end">
          <button onclick="window.saveAllDeliveries('${poId}')" class="px-4 py-2 bg-purple-600 text-white text-sm rounded-lg hover:bg-purple-700">
            Save All Changes
          </button>
        </div>
      </div>
    `;
  };

  (window as any).saveDelivery = async (itemId: string, poId: string) => {
    const container = document.getElementById(`po-items-${poId}`);
    if (!container) return;

    const deliveredInput = container.querySelector(`.delivered-input[data-item-id="${itemId}"]`) as HTMLInputElement;
    const notesInput = container.querySelector(`.notes-input[data-item-id="${itemId}"]`) as HTMLInputElement;

    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'update_delivery',
        items: [{ id: itemId, delivered_qty: parseInt(deliveredInput.value) || 0, delivery_notes: notesInput.value }],
      }),
    });

    if (resp.ok) loadPurchaseOrders();
    else alert('Failed to save delivery');
  };

  (window as any).saveAllDeliveries = async (poId: string) => {
    const container = document.getElementById(`po-items-${poId}`);
    if (!container) return;

    const items: any[] = [];
    container.querySelectorAll('.delivered-input').forEach((input: any) => {
      const itemId = input.dataset.itemId;
      const notesInput = container.querySelector(`.notes-input[data-item-id="${itemId}"]`) as HTMLInputElement;
      items.push({ id: itemId, delivered_qty: parseInt(input.value) || 0, delivery_notes: notesInput?.value || '' });
    });

    const resp = await fetch('/api/purchase-orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'update_delivery', items }),
    });

    if (resp.ok) {
      alert('Deliveries saved successfully.');
      loadPurchaseOrders();
    } else alert('Failed to save deliveries');
  };

  document.getElementById('companyFilter')?.addEventListener('change', loadPurchaseOrders);
  document.getElementById('statusFilter')?.addEventListener('change', loadPurchaseOrders);

  loadCompanies();
  loadPurchaseOrders();
</script>
